<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="viewmodel"
            type="mapitgis.jalnigamk.fhtc.screens.historylist.FHTCHistoryListVM" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context="mapitgis.jalnigamk.fhtc.screens.surveylist.FHTCSurveyListActivity">

        <include
            android:id="@+id/appbar"
            layout="@layout/toolbar" />


        <LinearLayout
            android:id="@+id/filter_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/appbar"
            android:padding="12dp"
            android:background="@color/cardview_light_background">

            <mapitgis.jalnigamk.nirmal.view.FormSpinner
                android:id="@+id/spin_village"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_vertical"
                app:mandatory="true"
                app:label="Village"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/search_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/filter_layout"
            android:padding="8dp"
            android:background="@color/gray"
            android:orientation="vertical">

            <EditText
                android:id="@+id/searchView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_search_edittext"
                android:drawableLeft="@drawable/ic_search"
                android:drawableTint="@color/gray"
                android:padding="6dp"
                android:hint="Search by name or mobile"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textColorHint="@color/gray"/>




        </LinearLayout>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/survey_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/search_card"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="4dp">

        </androidx.recyclerview.widget.RecyclerView>







    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>