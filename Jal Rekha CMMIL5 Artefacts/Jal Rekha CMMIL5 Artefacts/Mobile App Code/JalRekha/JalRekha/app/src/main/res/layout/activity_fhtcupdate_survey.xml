<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewmodel"
            type="mapitgis.jalnigamk.fhtc.screens.updatesurvey.FHTCUpdateSurveyVM" />

        
    
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context="mapitgis.jalnigamk.fhtc.screens.updatesurvey.FHTCUpdateSurveyActivity">


        <include
            android:id="@+id/appbar"
            layout="@layout/toolbar" />

        <TextView
            android:id="@+id/tv_searching_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            app:layout_constraintTop_toBottomOf="@id/appbar"
            android:text="Searching for location... Please wait"
            android:gravity="center"
            app:visibilityGone="@{viewmodel.geoLocation==null}"
            android:background="@color/colorYellow"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tv_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_searching_location"
            android:gravity="center"
            android:background="@color/gray_light"
            app:visibilityGone="@{viewmodel.distanceMeterMsg!=null}"
            android:text="@{viewmodel.distanceMeterMsg}"
            android:textSize="12sp"
            android:textColor="@color/colorPrimaryDark"/>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/top_map_view"
            android:layout_width="match_parent"
            android:layout_height="174dp"
            app:layout_constraintTop_toBottomOf="@id/tv_distance"
            app:cardCornerRadius="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <fragment
                    android:id="@+id/map"
                    android:name="mapitgis.jalnigamk.util.MySupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Transparent Overlay (For Handling Scroll & Touch) -->
                <View
                    android:id="@+id/touchInterceptor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/address_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_margin="12dp"
                    app:cardBackgroundColor="@color/transparent_color">

                    <TextView
                        android:id="@+id/tv_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableLeft="@drawable/ic_baseline_location_on_24"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/red"
                        android:padding="8dp"
                        android:textColor="@color/white"
                        android:text="@{viewmodel.geoAddress}"/>

                </com.google.android.material.card.MaterialCardView>

            </RelativeLayout>

        </com.google.android.material.card.MaterialCardView>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/top_map_view"
            app:layout_constraintBottom_toTopOf="@id/btn_submit">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/info_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="0dp"
                    app:cardCornerRadius="0dp"
                    app:cardBackgroundColor="@color/gray_light">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintTop_toTopOf="parent"
                            android:padding="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@{viewmodel.surveyInfo.nameEn}"
                                    android:textSize="14sp"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@{viewmodel.surveyInfo.mobileNumber}"
                                    android:drawableLeft="@drawable/outline_call_24"
                                    android:drawableTint="@color/colorPrimaryDark"
                                    android:autoLink="phone"/>



                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text='@{"Father/Husband: " + viewmodel.surveyInfo.fatherHusbandName}'
                                android:textSize="14sp"
                                android:textColor="@color/black"/>


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text='@{"FamilyId: " + viewmodel.surveyInfo.familyId}'
                                android:textSize="13sp"
                                android:textColor="@color/gray"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text='@{"SamagraId: " + viewmodel.surveyInfo.samagraId}'
                                android:textSize="13sp"
                                android:textColor="@color/gray"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text='@{"Water Connection Consent: " + viewmodel.surveyInfo.waterConnectionConsent}'
                                android:textSize="13sp"
                                android:textColor="@color/gray"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="12sp"
                                android:textColor="@color/gray"
                                android:text='@{"Address: " + viewmodel.surveyInfo.fullAddress}'/>


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text='@{"Survey Date: "+viewmodel.surveyInfo.parseDate()}'
                                android:textSize="12sp"
                                android:textColor="@color/gray"
                                app:drawableTint="@color/gray"
                                android:textStyle="bold"
                                android:gravity="center_vertical"/>

                        </LinearLayout>


                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_direction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:icon="@drawable/outline_navigation_24"
                            app:iconTint="@color/white"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintRight_toRightOf="parent"
                            app:backgroundTint="@color/colorPrimaryDark"
                            app:cornerRadius="8dp"
                            style="?attr/materialIconButtonStyle"
                            android:layout_margin="8dp"
                            app:visibilityGone="@{viewmodel.distanceMeterMsg!=null}"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>


                </com.google.android.material.card.MaterialCardView>



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="144dp"
                        android:layout_weight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/btn_capture"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/outline_photo_camera_24"
                                    app:tint="@color/colorPrimaryDark" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="12sp"
                                    android:textColor="@color/gray"
                                    android:gravity="center"
                                    android:text="Capture Water Tap Connection Image"/>

                            </LinearLayout>

                            <ImageView
                                android:id="@+id/tap_connection_image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@color/gray_light"
                                android:scaleType="centerCrop"/>

                        </LinearLayout>


                    </com.google.android.material.card.MaterialCardView>

                    <mapitgis.jalnigamk.nirmal.view.FormEditText
                        android:id="@+id/et_remark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:label="Remark"
                        app:hint="Enter Remark"
                        app:border="true"
                        android:orientation="vertical"
                        android:singleLine="false"
                        android:lines="2"
                        android:gravity="top|left"
                        android:imeOptions="actionDone"
                        android:layout_marginTop="8dp"/>


                </LinearLayout>

            </LinearLayout>


        </ScrollView>









        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_margin="16dp"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>