<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    tools:context=".rfi.activity.InspectionAssignActivity">

    <include
        android:id="@+id/inspection_assign_toolbar"
        layout="@layout/layout_toolbar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/inspection_assign_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/inspection_assign_toolbar"
        tools:listitem="@layout/layout_inspection_assign_list"/>

    <TextView
        android:id="@+id/inspection_assing_no_data_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="No data found"
        android:textStyle="bold"
        android:textColor="@color/redColor"
        android:textSize="16sp"/>

</RelativeLayout>