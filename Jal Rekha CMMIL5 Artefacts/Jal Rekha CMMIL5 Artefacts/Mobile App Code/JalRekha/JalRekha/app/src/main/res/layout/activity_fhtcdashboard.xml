<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewmodel"
            type="mapitgis.jalnigamk.fhtc.screens.dashboard.FHTCDashboardVM" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context="mapitgis.jalnigamk.fhtc.screens.dashboard.FHTCDashboardActivity">

        <include
            android:id="@+id/appbar"
            layout="@layout/toolbar" />


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:id="@+id/top_layout"
            app:layout_constraintTop_toBottomOf="@id/appbar"
            app:layout_constraintStart_toStartOf="parent"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:layout_margin="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:gravity="center"
                        android:text='@{"" + (viewmodel.totalSurveyCount != null ? viewmodel.totalSurveyCount : 0)}'
                        android:textSize="18sp"
                        android:textColor="@android:color/black"
                        android:background="@drawable/circle_bg" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textColor="@color/black"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/gray_light"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:gravity="center"
                        android:text='@{"" + (viewmodel.totalDraftCount != null ? viewmodel.totalDraftCount : 0)}'
                        android:textSize="18sp"
                        android:textColor="@android:color/black"
                        android:background="@drawable/circle_bg" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Draft"
                        android:textColor="@color/black"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/gray_light"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/circle_bg"
                        android:gravity="center"
                        android:text='@{"" + (viewmodel.totalCompletedCount != null ? viewmodel.totalCompletedCount : 0)}'
                        android:textColor="@android:color/black"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completed"
                        android:textColor="@color/black"/>

                </LinearLayout>

            </LinearLayout>


        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/top_layout"
            app:layout_constraintBottom_toBottomOf="parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <mapitgis.jalnigamk.fhtc.view.FHTCDashboardButton
                android:id="@+id/btn_download"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:ucv_icon="@drawable/ic_download_white"
                app:ucv_title="Download"
                app:ucv_subtitle="Download village data from server"/>

            <mapitgis.jalnigamk.fhtc.view.FHTCDashboardButton
                android:id="@+id/btn_survey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:ucv_icon="@drawable/ic_baseline_location_on_24"
                app:ucv_title="FHTC Survey"
                app:ucv_subtitle="Functional Household Tap Connection Survey"
                android:layout_marginTop="12dp"/>


            <mapitgis.jalnigamk.fhtc.view.FHTCDashboardButton
                android:id="@+id/btn_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:ucv_icon="@drawable/ic_sync"
                app:ucv_title="Sync Offline Data"
                app:ucv_subtitle="Upload local saved data to server"
                android:layout_marginTop="12dp"
                android:onClick="@{viewmodel.syncOfflineData}"/>

            <mapitgis.jalnigamk.fhtc.view.FHTCDashboardButton
                android:id="@+id/btn_draft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:ucv_icon="@drawable/ic_edit"
                app:ucv_title="View/Delete Draft"
                app:ucv_subtitle="Manage your saved draft surveys"
                android:layout_marginTop="12dp"/>

            <mapitgis.jalnigamk.fhtc.view.FHTCDashboardButton
                android:id="@+id/btn_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:ucv_icon="@drawable/baseline_history_24"
                app:ucv_title="History"
                app:ucv_subtitle="View completed surveys"
                android:layout_marginTop="12dp"/>


        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>