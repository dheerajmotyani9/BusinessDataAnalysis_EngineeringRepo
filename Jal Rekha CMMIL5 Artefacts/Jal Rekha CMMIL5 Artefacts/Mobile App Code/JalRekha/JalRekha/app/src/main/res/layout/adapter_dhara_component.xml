<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/dp5"
    android:layout_marginEnd="@dimen/dp5"
    android:layout_marginBottom="-5dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/dp10"
    app:cardElevation="@dimen/dp2"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dp10"
            android:paddingEnd="@dimen/dp5">

            <TextView
                android:id="@+id/textViewType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="@string/oht"
                android:textAllCaps="true"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/textViewESR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAllCaps="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingStart="@dimen/dp10"
                android:singleLine="true"
                android:paddingEnd="@dimen/dp10"
                android:text="@string/app_name"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:scrollHorizontally="true"
                android:textColor="@color/black"
                android:textSize="12sp" />

            <Button
                android:id="@+id/buttonDetail"
                android:layout_width="wrap_content"
                style="@style/ButtonStyle"
                android:layout_height="35dp"
                android:text="@string/add_reading"
                android:textSize="10sp"
                android:textStyle="bold"
                app:backgroundTint="@color/colorPrimary"
                tools:ignore="SmallSp"
                />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dp10"
            android:paddingEnd="@dimen/dp10">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/textViewBeneficiary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/textViewDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAllCaps="true"
                    android:textColor="@color/gray"
                    android:textSize="12sp" />


                <TextView
                    android:id="@+id/textViewTotalReading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAllCaps="true"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/textViewR1Date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/start_reading_kl"
                    android:textAllCaps="true"
                    android:layout_marginTop="@dimen/dp5"
                    android:textColor="@color/red"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/imageViewTic"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/success_tic"
                android:contentDescription="@string/star"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp5"
            android:orientation="horizontal"
            android:paddingStart="@dimen/dp10"
            android:paddingEnd="@dimen/dp10">

            <mapitgis.jalnigam.core.ShadowLayout
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="-10dp"
                android:layout_marginTop="-10dp"
                app:shadow_background_color="@color/shadowColorBlack"
                app:shadow_corner_radius="10dp"
                app:shadow_elevation="5dp"
                app:shadow_highlight_color="@color/shadow_shadow_color_black"
                app:shadow_layer_type="software"
                app:shadow_shadow_color="@color/shadow_shadow_color_black"
                app:shadow_shadow_type="inner"
                app:shadow_view_type="rectangular"
                tools:viewBindingIgnore="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/dp5">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/start_reading_kl"
                        android:textAllCaps="true"
                        android:textColor="@color/green_light"
                        android:textSize="10sp"
                        tools:ignore="SmallSp" />

                    <TextView
                        android:id="@+id/textViewR1"
                        style="@style/MyDigitalTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/app_name"
                        android:textColor="@color/green_light"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </mapitgis.jalnigam.core.ShadowLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <mapitgis.jalnigam.core.ShadowLayout
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="-10dp"
                android:layout_marginEnd="-10dp"
                app:shadow_background_color="@color/shadowColorBlack"
                app:shadow_corner_radius="10dp"
                app:shadow_elevation="5dp"
                app:shadow_highlight_color="@color/shadow_shadow_color_black"
                app:shadow_layer_type="software"
                app:shadow_shadow_color="@color/shadow_shadow_color_black"
                app:shadow_shadow_type="inner"
                app:shadow_view_type="rectangular"
                tools:viewBindingIgnore="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/dp5">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/end_reading_kl"
                        android:textAllCaps="true"
                        android:textColor="@color/green_light"
                        android:textSize="10sp"
                        tools:ignore="SmallSp" />

                    <TextView
                        android:id="@+id/textViewR2"
                        style="@style/MyDigitalTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/app_name"
                        android:textColor="@color/green_light"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </mapitgis.jalnigam.core.ShadowLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>