<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".dhara.DharaDailyWaterSupplyActivity">

    <include
        android:id="@+id/dhara_history_toolbar"
        layout="@layout/layout_toolbar" />

    <EditText
        android:id="@+id/input_search_dhara_supply_history"
        android:layout_width="match_parent"
        android:background="@drawable/rect_line_shape"
        android:hint="@string/search_by_component"
        android:inputType="text"
        android:maxLines="1"
        android:layout_marginStart="15dp"
        android:layout_marginTop="8dp"
        android:layout_below="@id/dhara_history_toolbar"
        android:layout_marginEnd="15dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_height="40dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/daily_water_supply_recycler_view"
        android:layout_width="match_parent"
        android:layout_marginTop="10dp"
        android:layout_below="@id/input_search_dhara_supply_history"
        android:layout_height="wrap_content"
        tools:listitem="@layout/layout_daily_water_supply_list"/>

    <ProgressBar
        android:id="@+id/dhara_water_supply_progress_bar"
        android:layout_width="wrap_content"
        android:visibility="gone"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>

    <TextView
        android:id="@+id/no_dhara_water_supply_tv"
        android:layout_width="wrap_content"
        android:visibility="gone"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:textSize="18sp"
        android:textColor="@color/red"
        android:text="No data found"/>


</RelativeLayout>