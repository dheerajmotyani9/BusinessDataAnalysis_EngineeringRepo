<?xml version="1.0" encoding="utf-8"?>
<layout>

    <data>
        <import type="mapitgis.jalnigam.core.Utility"/>
        <variable
            name="nirmalVM"
            type="mapitgis.jalnigamk.nirmal.screens.wqm_add.WQMFormVM" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:background="@color/whiteGray">

        <include
            android:id="@+id/appbar"
            layout="@layout/toolbar" />

        <TextView
            android:id="@+id/tv_searching_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            app:layout_constraintTop_toBottomOf="@id/appbar"
            android:text="Searching for location... Please wait"
            android:gravity="center"
            app:visibilityGone="@{nirmalVM.geoLocation==null}"
            android:background="@color/colorYellow"/>


        <androidx.cardview.widget.CardView
            android:id="@+id/top_info_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tv_searching_location"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:id="@+id/tv_sampleid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="Sample Id"
                    app:value="@{nirmalVM.waterSampleId}"
                    app:valueTextColor="@color/green"/>

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:id="@+id/tv_current_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="Date"
                    app:value="@{Utility.getCurrentTimeSync()}"/>

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:id="@+id/tv_scheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="Scheme"
                    app:value="@{nirmalVM.surveyTransaction.schName}"/>

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:id="@+id/tv_water_point"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="Water Point"
                    app:value="@{nirmalVM.surveyTransaction.allotTypeName}"/>

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="Institute"
                    app:value="@{nirmalVM.surveyTransaction.institute}"
                    app:visibilityGone="@{nirmalVM.isInstituteOtherVisible()}"/>

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="ESR"
                    app:value="@{nirmalVM.surveyTransaction.esrName}"
                    app:visibilityGone="@{nirmalVM.isOHTESRVisible()}"/>


            </LinearLayout>


        </androidx.cardview.widget.CardView>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scrollview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/top_info_view"
            app:layout_constraintBottom_toTopOf="@id/btn_submit">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <mapitgis.jalnigamk.nirmal.view.FormSpinner
                    android:id="@+id/spin_village"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    app:mandatory="true"
                    app:label="Village"
                    app:visibilityGone="@{nirmalVM.surveyTransaction.isBeneficiaryType()}"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <mapitgis.jalnigamk.nirmal.view.FormLabel
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/colorPrimary"
                        android:textSize="14sp"
                        app:label="Sample Photo"
                        app:mandatory="true"/>

                    <Button
                        android:id="@+id/btn_sample_image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Image"/>

                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/sample_img_card"
                    android:layout_width="124dp"
                    android:layout_height="164dp"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="12dp"
                    android:visibility="gone"
                    app:contentPadding="8dp"
                    android:layout_gravity="right">

                    <ImageView
                        android:id="@+id/sample_photo_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:scaleType="fitXY"/>

                </androidx.cardview.widget.CardView>

                <!--beni detail-->
                <LinearLayout
                    android:id="@+id/beneficiary_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:visibilityGone="@{nirmalVM.isBenificiaryVisible()}">

                    <mapitgis.jalnigamk.nirmal.view.FormEditText
                        android:id="@+id/et_beni_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:label="Beneficiary Name"
                        app:mandatory="true"
                        app:hint="Enter name"
                        app:border="true"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"/>

                    <mapitgis.jalnigamk.nirmal.view.FormEditText
                        android:id="@+id/et_beni_mobile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:label="Beneficiary Mobile Number"
                        app:mandatory="true"
                        app:hint="Enter mobile number"
                        android:maxLength="10"
                        android:inputType="number"
                        app:border="true"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"/>

                    <mapitgis.jalnigamk.nirmal.view.FormEditText
                        android:id="@+id/et_beni_samagra"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:label="Beneficiary Samagra Id"
                        app:hint="Enter samagra id"
                        android:inputType="number"
                        android:maxLength="9"
                        app:border="true"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>

                <!--contact person details-->
                <LinearLayout
                    android:id="@+id/contact_person_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:visibilityGone="@{nirmalVM.isContactPersonVisible()}">

                    <mapitgis.jalnigamk.nirmal.view.FormEditText
                        android:id="@+id/et_contact_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:label="Contact Person Name"
                        app:mandatory="true"
                        app:hint="Enter name"
                        app:border="true"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"/>

                    <mapitgis.jalnigamk.nirmal.view.FormEditText
                        android:id="@+id/et_contact_mobile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:label="Contact Person Mobile"
                        app:mandatory="true"
                        android:maxLength="10"
                        android:inputType="number"
                        app:hint="Enter mobile number"
                        app:border="true"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"/>

                    <mapitgis.jalnigamk.nirmal.view.FormEditText
                        android:id="@+id/et_contact_designation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:label="Contact Person Designation"
                        app:mandatory="true"
                        app:hint="Enter designation"
                        app:border="true"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/frc_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:visibilityGone="@{nirmalVM.isFRCVisible}"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <mapitgis.jalnigamk.nirmal.view.FormLabel
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/colorPrimary"
                            android:textSize="14sp"
                            app:label="FRC Test Photo"
                            app:mandatory="true"/>

                        <Button
                            android:id="@+id/btn_frc_image"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Image"/>

                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/frc_img_card"
                        android:layout_width="124dp"
                        android:layout_height="164dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="12dp"
                        android:visibility="gone"
                        app:contentPadding="8dp"
                        android:layout_gravity="right">

                        <ImageView
                            android:id="@+id/frc_photo_preview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:scaleType="fitXY"/>

                    </androidx.cardview.widget.CardView>

                    <mapitgis.jalnigamk.nirmal.view.FormEditText
                        android:id="@+id/et_frc_result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:label="FRC Test Result(mg/L)"
                        app:mandatory="true"
                        app:border="true"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:inputType="numberDecimal"
                        android:maxLength="6"
                        android:gravity="center_vertical"/>

                </LinearLayout>

                <mapitgis.jalnigamk.nirmal.view.FormEditText
                    android:id="@+id/et_remark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:label="Remark"
                    app:hint="Enter Remark"
                    app:border="true"
                    android:orientation="vertical"
                    android:singleLine="false"
                    android:layout_marginTop="12dp"
                    android:lines="4"
                    android:gravity="top|left"
                    android:imeOptions="actionDone"/>



                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="12dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <fragment
                            android:id="@+id/map"
                            android:name="mapitgis.jalnigamk.util.MySupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <!-- Transparent Overlay (For Handling Scroll & Touch) -->
                        <View
                            android:id="@+id/touchInterceptor"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"/>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/address_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_margin="12dp"
                            app:cardBackgroundColor="@color/transparent_color">

                            <TextView
                                android:id="@+id/tv_address"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableLeft="@drawable/ic_baseline_location_on_24"
                                android:drawablePadding="8dp"
                                android:drawableTint="@color/white"
                                android:padding="8dp"
                                android:textColor="@color/white"
                                android:text="@{nirmalVM.geoAddress}"/>

                        </androidx.cardview.widget.CardView>

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>



        </androidx.core.widget.NestedScrollView>

        <Button
            android:id="@+id/btn_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="Submit"
            android:textSize="16sp"
            android:layout_margin="12dp"/>



    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>