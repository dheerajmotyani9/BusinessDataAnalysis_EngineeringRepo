            tools:ignore="DiscouragedApi,LockedOrientationActivity" />

        <activity
            android:name=".isa.AddISAActivity"
            android:label="Add सहभागिता Activity"
            android:screenOrientation="portrait"
            tools:ignore="DiscouragedApi,LockedOrientationActivity" />


        <activity
            android:name=".di.AddDIActivity"
            android:label="@string/daily_inspection"
            android:screenOrientation="portrait"
            tools:ignore="DiscouragedApi,LockedOrientationActivity" />
        <activity
            android:name=".di.DIActivity"
            android:label="@string/daily_inspection"
            android:screenOrientation="portrait"
            tools:ignore="DiscouragedApi,LockedOrientationActivity" />


        <activity
            android:name=".dhara1.DharaActivity"
            android:label="@string/daily_water_supply"
            android:screenOrientation="portrait"
            tools:ignore="DiscouragedApi,LockedOrientationActivity" />
        <activity
            android:name=".dhara1.AddReadingActivity"
            android:label="@string/add_reading"
            android:screenOrientation="portrait"
            tools:ignore="DiscouragedApi,LockedOrientationActivity" />

        <activity
            android:name=".PdfActivity"
            android:label="@string/document"
            android:screenOrientation="portrait"
            tools:ignore="DiscouragedApi,LockedOrientationActivity" />
        <activity
            android:name=".ImgActivity"
            android:label="@string/images"
            android:screenOrientation="portrait"
            tools:ignore="DiscouragedApi,LockedOrientationActivity" />
        <activity
            android:name=".MultiImgActivity"
            android:label="@string/images"
            android:screenOrientation="portrait"
            tools:ignore="DiscouragedApi,LockedOrientationActivity" />
        <!-- <meta-data -->
        <!-- android:name="com.google.android.geo.API_KEY" -->
        <!-- android:value="@string/google_map_key" /> -->
