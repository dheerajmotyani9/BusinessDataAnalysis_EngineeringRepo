        <activity
            android:name=".rfi.activity.ContractorDISurveyActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan|adjustResize"
            android:exported="false" />
        <activity
            android:screenOrientation="portrait"
            android:name=".rfi.activity.ContractorLogsActivity"
            android:windowSoftInputMode="adjustPan|adjustResize"
            android:exported="false" />
        <activity
            android:name=".rfi.activity.FullImageActivity"
            android:windowSoftInputMode="adjustPan|adjustResize"
            android:screenOrientation="portrait"
            android:exported="false" />
