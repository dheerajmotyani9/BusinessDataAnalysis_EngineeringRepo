            android:screenOrientation="portrait"
            android:exported="false" />
        <activity
            android:name=".rfi.activity.InspectionHistoryDetailActivity"
            android:windowSoftInputMode="adjustPan|adjustResize"
            android:screenOrientation="portrait"
            android:exported="false" />
        <activity
            android:name=".rfi.activity.InspectionHistoryActivity"
