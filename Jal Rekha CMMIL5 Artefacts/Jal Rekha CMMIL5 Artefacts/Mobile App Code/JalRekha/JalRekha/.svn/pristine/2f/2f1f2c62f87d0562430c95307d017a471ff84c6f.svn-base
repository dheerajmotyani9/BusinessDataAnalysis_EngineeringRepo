<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".dhara.fragment.DharaIntakeFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dhara_intake_recycler_view"
        android:layout_width="match_parent"
        tools:listitem="@layout/layout_dhara_intake_history_list"
        android:layout_height="wrap_content"/>

    <ProgressBar
        android:id="@+id/dhara_intake_progress_bar"
        android:layout_width="wrap_content"
        android:visibility="gone"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>

    <TextView
        android:id="@+id/no_dhara_intake_his_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"
        android:text="No data found"
        android:textSize="18sp"
        android:textColor="@color/red"/>

</RelativeLayout>