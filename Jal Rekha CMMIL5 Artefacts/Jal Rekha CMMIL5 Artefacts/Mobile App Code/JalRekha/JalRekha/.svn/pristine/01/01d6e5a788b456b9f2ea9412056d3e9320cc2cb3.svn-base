package mapitgis.jalnigam.nirmal.camera


import android.app.Activity
import android.content.Context
import android.content.Intent
import android.net.Uri
import android.os.Bundle
import android.provider.MediaStore
import android.view.View
import android.widget.Toast
import androidx.activity.result.contract.ActivityResultContracts
import androidx.appcompat.app.AppCompatActivity
import androidx.core.content.FileProvider
import mapitgis.jalnigam.BuildConfig
import mapitgis.jalnigam.core.Utility
import mapitgis.jalnigam.databinding.ActivityCameraBinding
import java.io.File


class CameraActivity : AppCompatActivity() {

    companion object{
        val KEY_IMAGE = "image_uri"
    }

    private val binding: ActivityCameraBinding by lazy {
        ActivityCameraBinding.inflate(layoutInflater)
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        //using camerx
        /*setContentView(binding.rootView)
        window.setFlags(
            WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON,
            WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON
        )
        initView();

        if (ContextCompat.checkSelfPermission(this, Manifest.permission.CAMERA) != PackageManager.PERMISSION_GRANTED) {
            cameraPermissionResult.launch(Manifest.permission.CAMERA)
        } else {
            Handler(Looper.getMainLooper()).postDelayed({
                startCamera()
            }, 500)
        }*/

        //-----------using intent-------------------//
        dispatchTakePictureIntent()
    }


    private fun initView(){
        binding.btnSave.setOnClickListener {
            val imageUri = binding.capturedImageView.tag as Uri
            imageUri?.let { setImageResult(it) }
        }

        binding.btnRetake.setOnClickListener {
            binding.imageLayout.visibility = View.GONE
            val imageUri = binding.capturedImageView.tag as Uri
            imageUri?.let { deleteImageFromUri(this@CameraActivity,it) }
        }
    }

    fun deleteImageFromUri(context: Context, imageUri: Uri): Boolean {
        return try {
            context.contentResolver.delete(imageUri, null, null) > 0
        } catch (e: Exception) {
            e.printStackTrace()
            false
        }
    }


    //--------------------------------------------------------//
    private val REQUEST_IMAGE_CAPTURE = 1
    private lateinit var photoUri: Uri

    private fun dispatchTakePictureIntent() {
        val takePictureIntent = Intent(MediaStore.ACTION_IMAGE_CAPTURE)
        if (takePictureIntent.resolveActivity(packageManager) != null) {
            val photoFile: File? = Utility.createImageFile(baseContext)
            photoFile?.also {
                photoUri = FileProvider.getUriForFile(this, String.format("%s.fileProvider", BuildConfig.APPLICATION_ID), it)
                takePictureIntent.putExtra(MediaStore.EXTRA_OUTPUT, photoUri)
                startActivityForResult(takePictureIntent, REQUEST_IMAGE_CAPTURE)
            }
        }
    }


    override fun onActivityResult(requestCode: Int, resultCode: Int, data: Intent?) {
        super.onActivityResult(requestCode, resultCode, data)
        if (requestCode == REQUEST_IMAGE_CAPTURE && resultCode == Activity.RESULT_OK) {
            setImageResult(photoUri)
        } else {
            setResult(Activity.RESULT_CANCELED)
            finish()
        }
    }

    fun setImageResult(uri: Uri){
        val resultIntent = Intent().apply {
            putExtra(KEY_IMAGE, uri.toString())
        }
        setResult(Activity.RESULT_OK, resultIntent)
        finish()
    }
}