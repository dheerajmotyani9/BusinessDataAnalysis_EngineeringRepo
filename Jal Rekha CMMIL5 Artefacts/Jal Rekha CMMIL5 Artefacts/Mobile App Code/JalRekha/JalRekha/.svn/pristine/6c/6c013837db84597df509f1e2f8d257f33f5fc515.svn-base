<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="ShadowLayout">
        <attr name="shadow_view_type" />
        <attr name="shadow_shadow_type" />
        <attr name="shadow_elevation" format="dimension" />
        <attr name="shadow_corner_radius" format="dimension" />
        <attr name="shadow_background_color" format="color" />
        <attr name="shadow_shadow_color" format="color" />
        <attr name="shadow_highlight_color" format="color" />
        <attr name="shadow_layer_type"/>
        <attr name="shadow_shadow_visible" format="boolean" />
    </declare-styleable>

    <attr name="shadow_view_type">
        <enum name="rectangular" value="1" />
        <enum name="circular" value="2" />
    </attr>

    <attr name="shadow_shadow_type">
        <enum name="outer" value="1" />
        <enum name="inner" value="2" />
    </attr>

    <attr name="shadow_layer_type">
        <enum name="software" value="1" />
        <enum name="hardware" value="2" />
    </attr>

    <color name="shadow_background_color">#F1F3F6</color>
    <color name="shadow_shadow_color">#D9DBDE</color>
    <color name="shadow_highlight_color">#FFFFFF</color>
    <color name="shadowColor">#000</color>


    <color name="shadowColorBlack">#262626</color>
    <color name="shadow_shadow_color_black">#D9000000</color>
    <color name="shadow_highlight_color_black">#000000</color>

    <dimen name="shadow_view_corner_radius">16dp</dimen>
    <dimen name="shadow_view_corner_radius_circle">500dp</dimen>
    <dimen name="shadow_view_elevation">5dp</dimen>
</resources>