<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_new1"
    android:orientation="vertical">

    <include
        android:id="@+id/appbar"
        layout="@layout/toolbar" />


    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/dp20"
            android:paddingTop="@dimen/dp10"
            android:paddingEnd="@dimen/dp20">

            <LinearLayout
                android:id="@+id/ll1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:text="@string/piu_name"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:id="@+id/linearLayoutPIU"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/dp10"
                        android:paddingEnd="@dimen/dp10"
                        tools:ignore="UseCompoundDrawables">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/select"
                            android:textColor="@color/gray_1"
                            android:textSize="11sp" />

                        <ImageView
                            android:layout_width="@dimen/dp20"
                            android:layout_height="@dimen/dp20"
                            android:contentDescription="@string/app_name"
                            android:src="@drawable/ic_arrow"
                            app:tint="@color/colorPrimary" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginTop="@dimen/dp5"
                    android:text="@string/scheme"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:id="@+id/linearLayoutScheme"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/dp10"
                        android:paddingEnd="@dimen/dp10"
                        tools:ignore="UseCompoundDrawables">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/select"
                            android:textColor="@color/gray_1"
                            android:textSize="11sp" />

                        <ImageView
                            android:layout_width="@dimen/dp20"
                            android:layout_height="@dimen/dp20"
                            android:contentDescription="@string/app_name"
                            android:src="@drawable/ic_arrow"
                            app:tint="@color/colorPrimary" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginTop="@dimen/dp5"
                    android:text="@string/component"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:id="@+id/linearLayoutComponent"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/dp10"
                        android:paddingEnd="@dimen/dp10"
                        tools:ignore="UseCompoundDrawables">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/select"
                            android:textColor="@color/gray_1"
                            android:textSize="11sp" />

                        <ImageView
                            android:layout_width="@dimen/dp20"
                            android:layout_height="@dimen/dp20"
                            android:contentDescription="@string/app_name"
                            android:src="@drawable/ic_arrow"
                            app:tint="@color/colorPrimary" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginTop="@dimen/dp5"
                    android:text="@string/village"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <EditText
                        android:id="@+id/editTextVillage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/village"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:lines="1"
                        android:maxLines="1"
                        android:paddingStart="@dimen/dp10"
                        android:paddingEnd="@dimen/dp10"
                        android:singleLine="true"
                        android:textColor="@color/colorPrimary"
                        android:textColorHint="@color/gray_1"
                        android:textCursorDrawable="@null"
                        android:textSize="14sp" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginTop="@dimen/dp5"
                    android:text="@string/gram_panchayat"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <EditText
                        android:id="@+id/editTextGP"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/gram_panchayat"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:lines="1"
                        android:maxLines="1"
                        android:paddingStart="@dimen/dp10"
                        android:paddingEnd="@dimen/dp10"
                        android:singleLine="true"
                        android:textColor="@color/colorPrimary"
                        android:textColorHint="@color/gray_1"
                        android:textCursorDrawable="@null"
                        android:textSize="14sp" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginTop="@dimen/dp5"
                    android:text="@string/block"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <EditText
                        android:id="@+id/editTextBlock"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/block"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:lines="1"
                        android:maxLines="1"
                        android:paddingStart="@dimen/dp10"
                        android:paddingEnd="@dimen/dp10"
                        android:singleLine="true"
                        android:textColor="@color/colorPrimary"
                        android:textColorHint="@color/gray_1"
                        android:textCursorDrawable="@null"
                        android:textSize="14sp" />

                </androidx.cardview.widget.CardView>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginTop="@dimen/dp5"
                    android:text="@string/application_type"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:id="@+id/linearLayoutApplicationType"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/dp10"
                        android:paddingEnd="@dimen/dp10"
                        tools:ignore="UseCompoundDrawables">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/select"
                            android:textColor="@color/gray_1"
                            android:textSize="11sp" />

                        <ImageView
                            android:layout_width="@dimen/dp20"
                            android:layout_height="@dimen/dp20"
                            android:contentDescription="@string/app_name"
                            android:src="@drawable/ic_arrow"
                            app:tint="@color/colorPrimary" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginTop="@dimen/dp5"
                    android:text="@string/description_of_inspection"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <EditText
                            android:id="@+id/editTextDescription"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:gravity="top|start"
                            android:hint="@string/description_of_inspection"
                            android:importantForAutofill="no"
                            android:inputType="textMultiLine"
                            android:padding="@dimen/dp10"
                            android:textColor="@color/colorPrimary"
                            android:textColorHint="@color/gray_1"
                            android:textCursorDrawable="@null"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|bottom"
                            android:layout_margin="@dimen/dp10"
                            android:gravity="bottom"
                            android:orientation="horizontal"
                            tools:ignore="UseCompoundDrawables">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/dp5"
                                android:text="@string/word_limit_500_max"
                                android:textColor="@color/gray_1" />

                            <ImageView
                                android:id="@+id/textViewMic1"
                                android:layout_width="@dimen/dp20"
                                android:layout_height="@dimen/dp20"
                                android:layout_marginStart="@dimen/dp5"
                                android:contentDescription="@string/app_name"
                                android:src="@drawable/ic_mic"
                                app:tint="@color/gray_1" />

                        </LinearLayout>

                    </FrameLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:text="@string/qa_and_qc_review"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:ignore="UnusedAttribute"
                        android:paddingBottom="@dimen/dp10"
                        android:paddingStart="@dimen/dp5"
                        android:paddingTop="@dimen/dp5"
                        android:paddingEnd="@dimen/dp5"
                        tools:itemCount="3"
                        tools:listitem="@layout/adapter_di_option" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginTop="@dimen/dp5"
                    android:text="@string/qa_and_qc_comments"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <EditText
                            android:id="@+id/editTextQaQcReview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:gravity="top|start"
                            android:hint="@string/qa_and_qc_comments"
                            android:importantForAutofill="no"
                            android:inputType="textMultiLine"
                            android:padding="@dimen/dp10"
                            android:textColor="@color/colorPrimary"
                            android:textColorHint="@color/gray_1"
                            android:textCursorDrawable="@null"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|bottom"
                            android:layout_margin="@dimen/dp10"
                            android:gravity="bottom"
                            android:orientation="horizontal"
                            tools:ignore="UseCompoundDrawables">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/dp5"
                                android:text="@string/word_limit_500_max"
                                android:textColor="@color/gray_1" />

                            <ImageView
                                android:id="@+id/textViewMic2"
                                android:layout_width="@dimen/dp20"
                                android:layout_height="@dimen/dp20"
                                android:layout_marginStart="@dimen/dp5"
                                android:contentDescription="@string/app_name"
                                android:src="@drawable/ic_mic"
                                app:tint="@color/gray_1" />

                        </LinearLayout>

                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp5">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp5"
                        android:text="@string/images"
                        android:textColor="@color/text_color"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/buttonAddImage"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:background="@drawable/button"
                        android:text="@string/add_image"/>

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewImages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    tools:ignore="UnusedAttribute"
                    tools:itemCount="3"
                    app:spanCount="2"
                    tools:listitem="@layout/adapter_image" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:text="@string/address"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/dp10"
                    app:cardUseCompatPadding="true">

                    <TextView
                        android:id="@+id/textViewLocation"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="start|top"
                        android:hint="@string/address"
                        android:padding="@dimen/dp10"
                        android:textColor="@color/colorPrimary"
                        android:textColorHint="@color/gray_1"
                        android:textSize="14sp" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <Button
                android:id="@+id/buttonSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp20"
                android:background="@drawable/button"
                android:text="@string/next" />

        </LinearLayout>

    </ScrollView>

