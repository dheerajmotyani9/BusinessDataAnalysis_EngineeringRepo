                ESRVillage esrVillage = esrVillageAdapter.getItem(i);
                SqLite.instance(this).GET_DHARA_READING(this, dharaComponent.getId(), dharaComponent.getMeterId(), esrVillage.getLgd(), today, (success, data) -> {
                    if (success && data != null) {
                        setUploadEnable();
                        esrVillage.setReading(data);
