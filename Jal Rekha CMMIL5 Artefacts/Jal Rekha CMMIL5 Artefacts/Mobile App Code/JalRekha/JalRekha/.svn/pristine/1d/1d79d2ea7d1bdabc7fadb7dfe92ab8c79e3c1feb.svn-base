<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="mapitgis.jalnigam.nirmal.screens.viewdetail.WQMDetailsVM" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/whiteGray">

        <include
            android:id="@+id/appbar"
            layout="@layout/toolbar" />


        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/appbar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@id/appbar"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Sample Id"
                    app:value="@{viewModel.surveyDetail.sampleId}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Scheme Name"
                    app:value="@{viewModel.surveyDetail.schemeName}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Water Point"
                    app:value="@{viewModel.surveyDetail.collectionType}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Date"
                    app:value="@{viewModel.surveyDetail.formattedDate}"
                    android:padding="4dp"/>


                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="ESR"
                    app:value="@{viewModel.surveyDetail.ohtName}"
                    app:visibilityGone="@{viewModel.surveyDetail.ohtName != null}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Village Name"
                    app:value="@{viewModel.surveyDetail.villageName}"
                    app:visibilityGone="@{viewModel.surveyDetail.villageName != null}"
                    android:padding="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tv_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="7"
                        android:textColor="@color/gray"
                        android:textSize="14sp"
                        android:text="Water Sample"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="3">

                        <ImageView
                            android:id="@+id/sample_img"
                            android:layout_width="96dp"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            app:imageUri="@{viewModel.surveyDetail.sampleImgFilePath}"/>

                    </RelativeLayout>

                </LinearLayout>


                <!-- beneficiary -->
                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Beneficiary Name"
                    app:value="@{viewModel.surveyDetail.beneficiaryName}"
                    app:visibilityGone="@{viewModel.surveyDetail.beneficiaryName != null}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Mobile"
                    app:value="@{viewModel.surveyDetail.beneficiaryMobile}"
                    app:visibilityGone="@{viewModel.surveyDetail.beneficiaryMobile != null}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Samagra Id"
                    app:value="@{viewModel.surveyDetail.beneficiarySamagraId}"
                    app:visibilityGone="@{viewModel.surveyDetail.beneficiaryName != null}"
                    android:padding="4dp"/>





                <!-- bulk water institute-->
                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Institute"
                    app:value="@{viewModel.surveyDetail.instituteOtherName}"
                    app:visibilityGone="@{viewModel.surveyDetail.instituteOtherName != null}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Contact Person"
                    app:value="@{viewModel.surveyDetail.contactPersonName}"
                    app:visibilityGone="@{viewModel.surveyDetail.contactPersonName != null}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Contact Person Mobile"
                    app:value="@{viewModel.surveyDetail.contactPersonMobile}"
                    app:visibilityGone="@{viewModel.surveyDetail.contactPersonMobile != null}"
                    android:padding="4dp"/>

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Designation"
                    app:value="@{viewModel.surveyDetail.contactPersonDesignation}"
                    app:visibilityGone="@{viewModel.surveyDetail.contactPersonDesignation != null}"
                    android:padding="4dp"/>


                <!--frc -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="4dp"
                    app:visibilityGone="@{viewModel.surveyDetail.frcImgFilePath!=null}">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="7"
                        android:textColor="@color/gray"
                        android:textSize="14sp"
                        android:text="Frc Sample"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="3">

                        <ImageView
                            android:id="@+id/frc_image"
                            android:layout_width="96dp"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            app:imageUri="@{viewModel.surveyDetail.frcImgFilePath}"/>

                    </RelativeLayout>

                </LinearLayout>


                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="FRC Result"
                    app:value="@{viewModel.surveyDetail.frcTestResult}"
                    app:visibilityGone="@{viewModel.surveyDetail.frcTestResult != null}"
                    android:padding="4dp"/>


                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="Remark"
                    app:value="@{viewModel.surveyDetail.remark}"
                    android:padding="4dp"/>


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_margin="4dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <fragment
                            android:id="@+id/map"
                            android:name="com.google.android.gms.maps.SupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />


                        <androidx.cardview.widget.CardView
                            android:id="@+id/address_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_margin="12dp"
                            app:cardBackgroundColor="@color/transparent_color">

                            <TextView
                                android:id="@+id/tv_address"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableLeft="@drawable/ic_baseline_location_on_24"
                                android:drawablePadding="8dp"
                                android:drawableTint="@color/white"
                                android:padding="8dp"
                                android:textColor="@color/white"
                                android:text="@{viewModel.geoAddress}"/>

                        </androidx.cardview.widget.CardView>

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>





            </LinearLayout>

        </androidx.core.widget.NestedScrollView>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>