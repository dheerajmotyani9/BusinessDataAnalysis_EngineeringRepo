    private void spinner(@NonNull SpinnerItem spinnerItem, @NonNull String source) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(S_KEY, spinnerItem.getKeyString());
        contentValues.put(S_NAME, spinnerItem.getValue());
        contentValues.put(S_SOURCE, source);
        contentValues.put(S_EXTRA1, "");
        db.insert(T_SPINNER, null, contentValues);
    }

    @NonNull
    private String spinnerQuery(@NonNull SpinnerItem spinnerItem, @NonNull String source, int i) {
        StringBuilder sb = new StringBuilder();
        if (i == 0) {
            sb.append("INSERT INTO " + T_SPINNER + "(" + S_KEY + "," + S_NAME + "," + S_SOURCE + "," + S_EXTRA1 + ") VALUES");
        } else {
            sb.append(",");
        }
        sb.append("('").append(spinnerItem.getKeyString().replace("'", " ")).append("','").append(spinnerItem.getValue().replace("'", " ")).append("','").append(source).append("','')");
        return sb.toString();
    }

    private void spinner(@NonNull SpinnerItem spinnerItem, @NonNull String source, @NonNull String extra) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(S_KEY, spinnerItem.getKeyString());
        contentValues.put(S_NAME, spinnerItem.getValue());
        contentValues.put(S_SOURCE, source);
        contentValues.put(S_EXTRA1, extra);
        db.insert(T_SPINNER, null, contentValues);
    }

    @NonNull
    private String spinnerQuery(@NonNull SpinnerItem spinnerItem, @NonNull String source, @NonNull String extra, int i) {
        StringBuilder sb = new StringBuilder();
        if (i == 0) {
            sb.append("INSERT INTO " + T_SPINNER + "(" + S_KEY + "," + S_NAME + "," + S_SOURCE + "," + S_EXTRA1 + ") VALUES");
        } else {
            sb.append(",");
        }
        sb.append("('").append(spinnerItem.getKeyString().replace("'", " ")).append("','").append(spinnerItem.getValue().replace("'", " ")).append("','").append(source).append("','").append(extra).append("')");
        return sb.toString();
    }


