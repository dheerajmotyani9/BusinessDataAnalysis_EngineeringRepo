    @NonNull
    private List<SpinnerItem> getSpinners(@NonNull String source, boolean isIntKey) {
        List<SpinnerItem> spinnerItems = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_SPINNER + " WHERE " + S_SOURCE + "=?", new String[]{source})) {// ORDER BY S_NAME
            while (cursor.moveToNext()) {
                if (isIntKey) {
                    spinnerItems.add(new SpinnerItem(cursor.getInt(cursor.getColumnIndexOrThrow(S_KEY)), cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA1))));
                } else {
                    spinnerItems.add(new SpinnerItem(cursor.getString(cursor.getColumnIndexOrThrow(S_KEY)), cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA1))));
                }
            }
        }
        return spinnerItems;
    }

    @NonNull
    private List<SpinnerItem> getSpinners(@NonNull String source, @NonNull String extra, boolean isIntKey) {
        List<SpinnerItem> spinnerItems = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_SPINNER + " WHERE " + S_SOURCE + "=? AND " + S_EXTRA1 + "=?", new String[]{source, extra})) {//ORDER BY S_NAME
            while (cursor.moveToNext()) {
                if (isIntKey) {
                    spinnerItems.add(new SpinnerItem(cursor.getInt(cursor.getColumnIndexOrThrow(S_KEY)), cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA1))));
                } else {
                    spinnerItems.add(new SpinnerItem(cursor.getString(cursor.getColumnIndexOrThrow(S_KEY)), cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA1))));
                }
            }
        }
        return spinnerItems;
    }

    @NonNull
    public List<SpinnerItem> GET_POINTS(@NonNull String scheme_id, @NonNull String cid, @Nullable String lgdCode) {
        List<SpinnerItem> spinnerItems = new ArrayList<>();
        if (lgdCode == null) {
            Log.e("lgdCode", "N/A");
            try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_SPINNER + " WHERE " + S_SOURCE + "=? AND " + S_KEY + " NOT IN (SELECT " + ALL_POINT_ID + " FROM " + T_ASSERT + " WHERE " + ALL_COMPONENT_ID + "='" + cid + "') AND " + S_EXTRA1 + "=? AND " + S_EXTRA2 + "=?", new String[]{"POINTS", scheme_id, cid})) {// ORDER BY S_NAME
                while (cursor.moveToNext()) {
                    spinnerItems.add(new SpinnerItem(cursor.getString(cursor.getColumnIndexOrThrow(S_KEY)), cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), new Point(cursor.getDouble(cursor.getColumnIndexOrThrow(S_EXTRA3)), cursor.getDouble(cursor.getColumnIndexOrThrow(S_EXTRA4)))));
                }
            }
        } else {
            Log.e("lgdCode", lgdCode);
            try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_SPINNER + " WHERE " + S_SOURCE + "=? AND " + S_KEY + " NOT IN (SELECT " + ALL_POINT_ID + " FROM " + T_ASSERT + " WHERE " + ALL_COMPONENT_ID + "='" + cid + "') AND " + S_EXTRA1 + "=? AND " + S_EXTRA2 + "=? AND " + S_EXTRA5 + "=?", new String[]{"POINTS", scheme_id, cid, lgdCode})) {// ORDER BY S_NAME
                while (cursor.moveToNext()) {
                    spinnerItems.add(new SpinnerItem(cursor.getString(cursor.getColumnIndexOrThrow(S_KEY)), cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), new Point(cursor.getDouble(cursor.getColumnIndexOrThrow(S_EXTRA3)), cursor.getDouble(cursor.getColumnIndexOrThrow(S_EXTRA4)))));
                }
            }
        }
        Log.e("lgdCode_C", spinnerItems.size() + " A");
        return spinnerItems;
    }

    @NonNull
    public List<SpinnerItem> GET_ESR_NEW(@NonNull String scheme_id, @NonNull String cid) {
        List<SpinnerItem> spinnerItems = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT DISTINCT " + S_EXTRA5 + "," + S_EXTRA6 + " FROM " + T_SPINNER + " WHERE " + S_SOURCE + "=? AND " + S_EXTRA1 + "=? AND " + S_EXTRA2 + "=?", new String[]{"POINTS", scheme_id, cid})) {// ORDER BY S_NAME
            while (cursor.moveToNext()) {
                spinnerItems.add(new SpinnerItem(cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA5)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA6))));
            }
        }
        return spinnerItems;
    }

    @NonNull
    public List<Asset> getAsset(boolean all, String imei) {
        List<Asset> spinnerItems = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_ASSERT + " WHERE " + (all ? (ALL_IMEI + "='" + imei + "'") : (ALL_UPLOADED + "=0")) + " ORDER BY " + ALL_SERIAL + " DESC", null)) {
            while (cursor.moveToNext()) {
                spinnerItems.add(new Asset(cursor.getLong(cursor.getColumnIndexOrThrow(ALL_SERIAL)), cursor.getString(cursor.getColumnIndexOrThrow(AA_PAST_POINT_ID)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_SCHEME_ID)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_SCHEME_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_ESR_ID)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_ESR_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_POINT_ID)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_POINT_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_COMPONENT_ID)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_COMPONENT_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_LAT)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_LNG)), cursor.getString(cursor.getColumnIndexOrThrow(A_REMARK)), cursor.getString(cursor.getColumnIndexOrThrow(A_PHOTO)), cursor.getString(cursor.getColumnIndexOrThrow(AA_DATE)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_DEPTH_COVER)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_DIAMETER)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_MATERIAL)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_ALIGNMENT)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_MATERIAL_INFO_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_MATERIAL_INFO_VALUE)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_LINE_JSON)), cursor.getInt(cursor.getColumnIndexOrThrow(ALL_UPLOADED)) == 1));
            }
        }
        return spinnerItems;
    }

    @NonNull
    public List<Line> getAssetLine() {
        List<Line> lines = new ArrayList<>();
//        try (Cursor cursor = db.rawQuery("SELECT t1." + ALL_POINT_NAME + ",t1." + ALL_LAT + ",t1." + ALL_LNG + ",t1." + ALL_LINE_JSON + ",IFNULL(t2." + ALL_LAT + ",0) AS t2_lat,IFNULL(t2." + ALL_LNG + ",0) AS t2_lng FROM " + T_ASSERT + " t1 LEFT JOIN " + T_ASSERT + " t2 ON t2." + ALL_POINT_ID + "=t1." + AA_PAST_POINT_ID + " AND t2." + ALL_COMPONENT_ID + "=t1." + ALL_COMPONENT_ID + " ORDER BY t1." + ALL_SERIAL + " DESC", null)) {
        try (Cursor cursor = db.rawQuery("SELECT " + ALL_POINT_NAME + "," + ALL_LINE_JSON + "," + ALL_LAT + "," + ALL_LNG + " FROM " + T_ASSERT + " ORDER BY " + ALL_SERIAL + " DESC", null)) {
            while (cursor.moveToNext()) {
                JSONArray jsonArray = null;
                try {
                    jsonArray = new JSONArray(cursor.getString(cursor.getColumnIndexOrThrow(ALL_LINE_JSON)));
                } catch (Exception ignore) {
                }
                lines.add(new Line(cursor.getString(cursor.getColumnIndexOrThrow(ALL_POINT_NAME)), new LatLng(cursor.getDouble(cursor.getColumnIndexOrThrow(ALL_LAT)), cursor.getDouble(cursor.getColumnIndexOrThrow(ALL_LNG))), jsonArray));//, cursor.getDouble(cursor.getColumnIndexOrThrow("t2_lat")) == 0 ? null : new LatLng(cursor.getDouble(cursor.getColumnIndexOrThrow("t2_lat")), cursor.getDouble(cursor.getColumnIndexOrThrow("t2_lng")))
            }
        }
        return lines;
    }


