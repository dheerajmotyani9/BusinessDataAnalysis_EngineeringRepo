    public void setAssetUploaded(long serial) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(ALL_UPLOADED, 1);
        db.update(T_ASSERT, contentValues, ALL_SERIAL + "=" + serial, null);
    }

    public void setDIUploaded(long serial) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(ALL_UPLOADED, 1);
        db.update(T_DAILY_INSPECTION, contentValues, ALL_SERIAL + "=" + serial, null);
    }


    public void CLEAR_UPLOADED_ASSETS() {
