    public void CLEAR_DHARA_ESR_VILLAGE() {
        clearSpinner("DHARA_ESR_VILLAGE");
    }

    public void ADD_DHARA_ESR_VILLAGE(@NonNull ESRVillage village) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(S_SOURCE, "DHARA_ESR_VILLAGE");
        contentValues.put(S_KEY, village.getLgd());
        contentValues.put(S_NAME, village.getName());
        contentValues.put(S_EXTRA1, village.getEsrId());
        contentValues.put(S_EXTRA2, village.getEsr());
        contentValues.put(S_EXTRA3, village.getR1());
        contentValues.put(S_EXTRA4, village.getR2New());
        contentValues.put(S_EXTRA5, village.getRemark());
        contentValues.put(S_EXTRA6, village.getPhoto());
        contentValues.put(S_EXTRA7, village.getR1Date().replace(" 00:00:00", "").replace("null", ""));
        contentValues.put(S_EXTRA8, village.getDate());
        contentValues.put(S_EXTRA9, village.getMeterStatusId());
        contentValues.put(S_EXTRA10, village.getMeterStatusName());
        contentValues.put(S_EXTRA11, village.getWs());
        contentValues.put(S_EXTRA12, village.getEsrSUID());
        db.insert(T_SPINNER, null, contentValues);
//        this.spinner(village, "DHARA_ESR_VILLAGE", esr);
    }

    public List<ESRVillage> GET_DHARA_ESR_VILLAGE(String esrSUID, boolean today) {
        String date = today ? Utility.getCurrentDate().second : Utility.getCurrentDate(1).second;
        List<ESRVillage> esrVillages = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_SPINNER + " WHERE " + S_SOURCE + "='DHARA_ESR_VILLAGE' AND " + S_EXTRA12 + "=? AND " + S_EXTRA8 + "=? ORDER BY " + S_NAME, new String[]{String.valueOf(esrSUID), date})) {
            while (cursor.moveToNext()) {
                esrVillages.add(new ESRVillage(
                        cursor.getInt(cursor.getColumnIndexOrThrow(S_KEY)),
                        cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)),
                        cursor.getInt(cursor.getColumnIndexOrThrow(S_EXTRA1)),
                        cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA12)),
                        cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA2)),
                        cursor.getDouble(cursor.getColumnIndexOrThrow(S_EXTRA3)),
                        cursor.getDouble(cursor.getColumnIndexOrThrow(S_EXTRA4)),
                        cursor.getDouble(cursor.getColumnIndexOrThrow(S_EXTRA11)),
                        cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA5)),
                        cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA6)),
                        cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA7)),
                        cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA8)),
                        cursor.getInt(cursor.getColumnIndexOrThrow(S_EXTRA9)),
                        cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA10))
                ));
            }
        }
        return esrVillages;
//        return this.getSpinners("DHARA_ESR_VILLAGE", esr);
    }

    public void CLEAR_DHARA_COMPONENT() {
        db.delete(T_DHARA_COMPONENT, null, null);
    }

    public void ADD_DHARA_COMPONENT(@NonNull DharaComponent dharaComponent) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(DC_ID, dharaComponent.getId());
        contentValues.put(DC_NAME, dharaComponent.getName());
        contentValues.put(DC_TYPE, dharaComponent.getType());
        contentValues.put(ALL_SCHEME_ID, dharaComponent.getSchemeId());
        contentValues.put(ALL_SCHEME_NAME, dharaComponent.getScheme());
        contentValues.put(DC_WTP_ID, dharaComponent.getWtpId());
        contentValues.put(ALL_ESR_ID, dharaComponent.getEsrId());
        contentValues.put(ALL_ESR_SUID, dharaComponent.getEsrSUID());
        contentValues.put(ALL_ESR_NAME, dharaComponent.getEsr());
        contentValues.put(DC_B_ID, dharaComponent.getBid());
        contentValues.put(DC_B_NAME, dharaComponent.getBeneficiary());

        contentValues.put(DC_METER_ID, dharaComponent.getMeterId());
        contentValues.put(DC_METER_NAME, dharaComponent.getMeter());
        contentValues.put(DC_R1, dharaComponent.getR1());
        contentValues.put(DC_R2, dharaComponent.getR2New());
        contentValues.put(DC_WS, dharaComponent.getWs());

        contentValues.put(DC_REMARK, dharaComponent.getRemark());
        contentValues.put(DC_PHOTO, dharaComponent.getPhoto());
        contentValues.put(DC_R1_DATE, dharaComponent.getR1Date().replace(" 00:00:00", "").replace("null", ""));
        contentValues.put(DC_DATE, dharaComponent.getDate());


        contentValues.put(ALL_LAT, dharaComponent.getLat());
        contentValues.put(ALL_LNG, dharaComponent.getLng());

        contentValues.put(DC_METER_STATUS_ID, dharaComponent.getMeterStatusId());
        contentValues.put(DC_METER_STATUS_NAME, dharaComponent.getMeterStatusName());

        db.insert(T_DHARA_COMPONENT, null, contentValues);
    }

    @Nullable
    public List<DharaComponent> GET_DHARA_COMPONENT(@NonNull String schemeId, boolean today) {
        String date = today ? Utility.getCurrentDate().second : Utility.getCurrentDate(1).second;
        List<DharaComponent> dharaComponents = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_DHARA_COMPONENT + " WHERE " + ALL_SCHEME_ID + "=? AND " + DC_DATE + "=? order by " + DC_TYPE + "," + DC_ID, new String[]{schemeId, date})) {
            while (cursor.moveToNext()) {
                dharaComponents.add(getDharaCByCursor(cursor, today));
            }
        }
        return dharaComponents;
    }

    @NonNull
    private DharaComponent getDharaCByCursor(@NonNull Cursor cursor, boolean today) {
        String date = today ? Utility.getCurrentDate().second : Utility.getCurrentDate(1).second;
        String dateNextPrevious = today ? Utility.getCurrentDate(1).second : Utility.getCurrentDate().second;
        boolean allFilled = true;
        int type = cursor.getInt(cursor.getColumnIndexOrThrow(DC_TYPE));
        String esr_suid = cursor.getString(cursor.getColumnIndexOrThrow(ALL_ESR_SUID));
        int id = cursor.getInt(cursor.getColumnIndexOrThrow(DC_ID));
        int meter_id = cursor.getInt(cursor.getColumnIndexOrThrow(DC_METER_ID));
        if (type == 3) {
            //Check ALL Village Filled
            try (Cursor cursor1 = db.rawQuery("SELECT count(*) AS total FROM " + T_SPINNER + " WHERE " + S_SOURCE + "='DHARA_ESR_VILLAGE' AND " + S_EXTRA12 + "=? AND " + S_EXTRA8 + "=? AND CAST(" + S_EXTRA4 + " AS REAL)<=0 AND CAST(" + S_EXTRA11 + " AS REAL)<=0", new String[]{String.valueOf(esr_suid), date})) {
                if (cursor1.moveToNext()) {
                    allFilled = cursor1.getInt(cursor1.getColumnIndexOrThrow("total")) == 0;
                }
            }
        }

        boolean isNPFilled = false;
        //Check Today OR YESTERDAY is Filled.
        try (Cursor cursor2 = db.rawQuery("SELECT " + DC_R2 + "," + DC_WS + " FROM " + T_DHARA_COMPONENT + " WHERE " + DC_ID + "=? AND " + DC_METER_ID + "=? AND " + DC_DATE + "=?", new String[]{String.valueOf(id), String.valueOf(meter_id), dateNextPrevious})) {
            if (cursor2.moveToNext()) {
                isNPFilled = (cursor2.getDouble(cursor2.getColumnIndexOrThrow(DC_R2)) > 0 || cursor2.getDouble(cursor2.getColumnIndexOrThrow(DC_WS)) > 0);
            }
        }

        return new DharaComponent(
                type,
                id,
                cursor.getString(cursor.getColumnIndexOrThrow(DC_NAME)),
                cursor.getInt(cursor.getColumnIndexOrThrow(ALL_SCHEME_ID)),
                cursor.getString(cursor.getColumnIndexOrThrow(ALL_SCHEME_NAME)),
                cursor.getInt(cursor.getColumnIndexOrThrow(DC_WTP_ID)),
                cursor.getInt(cursor.getColumnIndexOrThrow(ALL_ESR_ID)),
                esr_suid,
                cursor.getString(cursor.getColumnIndexOrThrow(ALL_ESR_NAME)),
                cursor.getInt(cursor.getColumnIndexOrThrow(DC_B_ID)),
                cursor.getString(cursor.getColumnIndexOrThrow(DC_B_NAME)),
                meter_id,
                cursor.getString(cursor.getColumnIndexOrThrow(DC_METER_NAME)),
                cursor.getDouble(cursor.getColumnIndexOrThrow(DC_R1)),
                cursor.getDouble(cursor.getColumnIndexOrThrow(DC_R2)),
                cursor.getDouble(cursor.getColumnIndexOrThrow(DC_WS)),
                cursor.getString(cursor.getColumnIndexOrThrow(DC_REMARK)),
                cursor.getString(cursor.getColumnIndexOrThrow(DC_PHOTO)),
                cursor.getString(cursor.getColumnIndexOrThrow(DC_R1_DATE)),
                cursor.getString(cursor.getColumnIndexOrThrow(DC_DATE)),
                cursor.getDouble(cursor.getColumnIndexOrThrow(ALL_LAT)),
                cursor.getDouble(cursor.getColumnIndexOrThrow(ALL_LNG)),
                cursor.getInt(cursor.getColumnIndexOrThrow(DC_METER_STATUS_ID)),
                cursor.getString(cursor.getColumnIndexOrThrow(DC_METER_STATUS_NAME)),
                allFilled,
                isNPFilled
        );
    }


    @Nullable
    public DharaComponent GET_DHARA_COMPONENT_ONLY(int mappingId, int meterId, boolean today) {
        String date = today ? Utility.getCurrentDate().second : Utility.getCurrentDate(1).second;
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_DHARA_COMPONENT + " WHERE " + DC_ID + "=? AND " + DC_METER_ID + "=? AND " + DC_DATE + "=?", new String[]{String.valueOf(mappingId), String.valueOf(meterId), date})) {
            if (cursor.moveToNext()) {
                return getDharaCByCursor(cursor, today);
            }
        }
        return null;
    }


    @NonNull
    public List<SpinnerItem> GET_DHARA_SCHEME() {
        List<SpinnerItem> spinnerItems = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT DISTINCT " + ALL_SCHEME_ID + "," + ALL_SCHEME_NAME + " FROM " + T_DHARA_COMPONENT, null)) {// ORDER BY S_NAME
            while (cursor.moveToNext()) {
                spinnerItems.add(new SpinnerItem(cursor.getString(cursor.getColumnIndexOrThrow(ALL_SCHEME_ID)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_SCHEME_NAME))));
            }
        }
        return spinnerItems;
    }

    public void ADD_READING(@NonNull Context context, @NonNull Reading reading, boolean isVillage) throws Exception {
        ContentValues contentValues = new ContentValues();
        contentValues.put(DH_MAPPING_ID, reading.getMappingId());
        contentValues.put(DH_MAIN_ID, reading.getMainId());
        contentValues.put(DH_TYPE_ID, reading.getTypeId());
        contentValues.put(DH_TYPE_NAME, reading.getType());
        contentValues.put(DH_METER_ID, reading.getMeterId());
        contentValues.put(DH_START_READING, reading.getR1());
        contentValues.put(DH_END_READING, reading.getR2());
        contentValues.put(DH_TOTAL_WS, reading.getWs());
        contentValues.put(DH_END_REMARK, reading.getRemark());
        contentValues.put(DH_END_LAT, reading.getLatLng().latitude);
        contentValues.put(DH_END_LNG, reading.getLatLng().longitude);
        contentValues.put(DH_END_DATE, reading.getDate());
        contentValues.put(DH_END_TIME, reading.getTime());

        contentValues.put(DH_METER_STATUS_ID, reading.getMeterStatusId());
        contentValues.put(DH_METER_STATUS_NAME, reading.getMeterStatusName());

        long id = 0;
        if (isVillage) {
            contentValues.put(DH_LGD, reading.getLgdId());
            contentValues.put(DH_VILLAGE, reading.getVillage());

            try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_DHARA + " WHERE " + DH_MAPPING_ID + "=? AND " + DH_LGD + "=? AND " + DH_END_DATE + "=?", new String[]{String.valueOf(reading.getMappingId()), String.valueOf(reading.getLgdId()), reading.getDate()})) {// ORDER BY S_NAME
                if (cursor.moveToNext()) {
                    id = cursor.getInt(cursor.getColumnIndexOrThrow(ALL_SERIAL));
                }
            }
        } else {
            contentValues.put(DH_LGD, 0);
            contentValues.put(DH_VILLAGE, "");
            try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_DHARA + " WHERE " + DH_MAPPING_ID + "=? AND " + DH_METER_ID + "=? AND " + DH_LGD + "=0 AND " + DH_END_DATE + "=?", new String[]{String.valueOf(reading.getMappingId()), String.valueOf(reading.getMeterId()), reading.getDate()})) {// ORDER BY S_NAME
                if (cursor.moveToNext()) {
                    id = cursor.getInt(cursor.getColumnIndexOrThrow(ALL_SERIAL));
                }
            }
        }

        if (id > 0) {
            db.update(T_DHARA, contentValues, ALL_SERIAL + "=?", new String[]{String.valueOf(id)});
            clearBase64(id, T_DHARA, context);
            saveBase64(id, reading.getPhoto(), T_DHARA, context, (success, jsonArray, base64) -> {
            });
        } else {
            id = db.insert(T_DHARA, null, contentValues);
            if (id == -1) {
                throw new Exception("Something is wrong.");
            }
            saveBase64(id, reading.getPhoto(), T_DHARA, context, (success, jsonArray, base64) -> {
            });
        }
        if (!isVillage) {
            if (reading.readings != null && !reading.readings.isEmpty()) {
                for (int i = 0; i < reading.readings.size(); i++) {
                    Reading r = reading.readings.get(i);
                    ADD_READING(context, r, true);
                }
            }
        }
    }

//    public void CLEAR_DHARA_READING(long serial, @NonNull Context context) {
//        db.delete(T_DHARA, ALL_SERIAL + "=" + serial, null);
//        clearBase64(serial, T_DHARA, context);
//    }


    public void GET_DHARA_READING(@NonNull Context context, int mapping_id, int meter_id, int lgd, boolean today, @NonNull OnDataReceived<Reading> onDataReceived) {
        String date = today ? Utility.getCurrentDate().second : Utility.getCurrentDate(1).second;
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_DHARA + " WHERE " + DH_MAPPING_ID + "=? AND " + DH_METER_ID + "=? AND " + DH_LGD + "=? AND " + DH_END_DATE + "=?", new String[]{String.valueOf(mapping_id), String.valueOf(meter_id), String.valueOf(lgd), date})) {// ORDER BY S_NAME
            if (cursor.moveToNext()) {
                long id = cursor.getInt(cursor.getColumnIndexOrThrow(ALL_SERIAL));

                Reading reading = new Reading(
                        cursor.getInt(cursor.getColumnIndexOrThrow(DH_MAPPING_ID)),
                        cursor.getInt(cursor.getColumnIndexOrThrow(DH_MAIN_ID)),
                        cursor.getInt(cursor.getColumnIndexOrThrow(DH_TYPE_ID)),
                        cursor.getString(cursor.getColumnIndexOrThrow(DH_TYPE_NAME)),
                        cursor.getInt(cursor.getColumnIndexOrThrow(DH_METER_ID)),
                        cursor.getDouble(cursor.getColumnIndexOrThrow(DH_START_READING)),
                        cursor.getDouble(cursor.getColumnIndexOrThrow(DH_END_READING)),
                        cursor.getDouble(cursor.getColumnIndexOrThrow(DH_TOTAL_WS)),
                        new LatLng(cursor.getDouble(cursor.getColumnIndexOrThrow(DH_END_LAT)),
                                cursor.getDouble(cursor.getColumnIndexOrThrow(DH_END_LNG))),
                        cursor.getString(cursor.getColumnIndexOrThrow(DH_END_REMARK)),
                        cursor.getString(cursor.getColumnIndexOrThrow(DH_END_DATE)),
                        cursor.getString(cursor.getColumnIndexOrThrow(DH_END_TIME)),
                        cursor.getInt(cursor.getColumnIndexOrThrow(DH_METER_STATUS_ID)),
                        cursor.getString(cursor.getColumnIndexOrThrow(DH_METER_STATUS_NAME))
                );
                getBase64(id, T_DHARA, context, (success, jsonArray, base64) -> {
                    if (success && jsonArray != null && jsonArray.length() > 0) {
                        reading.setPhoto(jsonArray.optString(0));
                        onDataReceived.get(true, reading);
                    } else {
                        onDataReceived.get(false, null);
                    }
                });
            } else {
                onDataReceived.get(false, null);
            }
        }
    }


    public void discardDharaReading(long mapping_id, int meter_id, boolean today, @NonNull Context context) {
        String date = today ? Utility.getCurrentDate().second : Utility.getCurrentDate(1).second;
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_DHARA + " WHERE " + DH_MAPPING_ID + "=? AND " + DH_METER_ID + "=? AND " + DH_END_DATE + "=?", new String[]{String.valueOf(mapping_id), String.valueOf(meter_id), date})) {// ORDER BY S_NAME
            while (cursor.moveToNext()) {
                long id = cursor.getInt(cursor.getColumnIndexOrThrow(ALL_SERIAL));
                clearBase64(id, T_DHARA, context);
            }
        }
        db.delete(T_DHARA, DH_MAPPING_ID + "=? AND " + DH_METER_ID + "=? AND " + DH_END_DATE + "=?", new String[]{String.valueOf(mapping_id), String.valueOf(meter_id), date});
    }
