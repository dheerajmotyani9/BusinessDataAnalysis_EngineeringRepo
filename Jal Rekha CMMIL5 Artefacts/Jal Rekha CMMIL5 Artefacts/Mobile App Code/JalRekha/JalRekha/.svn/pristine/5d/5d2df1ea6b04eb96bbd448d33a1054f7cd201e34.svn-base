        clearBase64(serial, T_DAILY_INSPECTION, context);
//        db.delete(T_PHOTO, ALL_SERIAL + "=" + serial + " AND " + S_EXTRA1 + "='" + T_DAILY_INSPECTION + "'", null);
    }

    public void login(@NonNull Login login) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(L_USER_ID, login.getId());
        contentValues.put(L_ROLE_ID, login.getRoleId());
        contentValues.put(L_ROLE, login.getRole());
        contentValues.put(L_NAME, login.getName());
        contentValues.put(L_EMAIL, login.getEmail());
        contentValues.put(L_MOBILE, login.getMobile());
        contentValues.put(L_DISTRICT, login.getDistrict());
        contentValues.put(L_DESIGNATION, login.getDesignation());
        contentValues.put(L_MODULE, login.getModule());
        contentValues.put(L_TOKEN, login.getToken());
        Log.e("ABCD_I", "insert");
        db.insert(T_LOGIN, null, contentValues);
    }

    public void updateProfile(@NonNull Login login) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(L_NAME, login.getName());
        contentValues.put(L_EMAIL, login.getEmail());
        contentValues.put(L_MOBILE, login.getMobile());
        contentValues.put(L_DISTRICT, login.getDistrict());
        contentValues.put(L_DESIGNATION, login.getDesignation());
        contentValues.put(L_USER_ID, login.getId());
        Log.e("ABCD_I", "update");
        db.update(T_LOGIN, contentValues, null, null);
    }

    public Login getLogin() {
        Login login = null;
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_LOGIN, null)) {
            if (cursor.moveToNext()) {
                login = new Login(cursor.getLong(cursor.getColumnIndexOrThrow(L_USER_ID)), cursor.getString(cursor.getColumnIndexOrThrow(L_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(L_EMAIL)), cursor.getString(cursor.getColumnIndexOrThrow(L_MOBILE)), cursor.getString(cursor.getColumnIndexOrThrow(L_DISTRICT)), cursor.getString(cursor.getColumnIndexOrThrow(L_DESIGNATION)), cursor.getInt(cursor.getColumnIndexOrThrow(L_ROLE_ID)), cursor.getString(cursor.getColumnIndexOrThrow(L_ROLE)), cursor.getString(cursor.getColumnIndexOrThrow(L_TOKEN)), cursor.getString(cursor.getColumnIndexOrThrow(L_MODULE)));//, cursor.getString(cursor.getColumnIndexOrThrow(L_DID))
            }
        }
        return login;
    }

    public void logout() {
        db.delete(T_LOGIN, null, null);
        db.delete(T_LAST_SYNC, null, null);
    }

    @Nullable
    public String getLastTime(@NonNull Module module) {
        try (Cursor cursor = db.rawQuery("SELECT " + S_NAME + " FROM " + T_LAST_SYNC + " WHERE " + S_KEY + "='" + module.code + "'", null)) {
            if (cursor.moveToNext()) {
                return cursor.getString(cursor.getColumnIndexOrThrow(S_NAME));
            }
        }
        return null;
    }

    public void updateLastTime(@NonNull Module module) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(S_NAME, Utility.getCurrentTimeSync());
        if (getLastTime(module) == null) {
            contentValues.put(S_KEY, module.code);
            db.insert(T_LAST_SYNC, null, contentValues);
        } else {
            db.update(T_LAST_SYNC, contentValues, S_KEY + "='" + module.code + "'", null);
        }
    }

    public void resetLastTime(@NonNull Module module) {
//        ContentValues contentValues = new ContentValues();
//        contentValues.putNull(S_NAME);
//        db.update(T_LOGIN, contentValues, S_KEY+"='"+module.name+"'", null);
        db.delete(T_LAST_SYNC, S_KEY + "='" + module.code + "'", null);
    }

    public List<SpinnerItem> GET_ALIGNMENT() {
        List<SpinnerItem> spinnerItems = new ArrayList<>();
        spinnerItems.add(new SpinnerItem("Left", "Left"));
        spinnerItems.add(new SpinnerItem("Right", "Right"));
        spinnerItems.add(new SpinnerItem("Center", "Center"));
        spinnerItems.add(new SpinnerItem("", "Other"));
        return spinnerItems;
    }

    public String GET_REVIEW_DI_NEW(String id) {
        try (Cursor cursor = db.rawQuery("SELECT " + S_NAME + " FROM " + T_SPINNER + " WHERE " + S_KEY + "=? AND " + S_SOURCE + "=?", new String[]{id, "QA_QC_REVIEW_DI"})) {
            if (cursor.moveToNext()) {
                return cursor.getString(cursor.getColumnIndexOrThrow(S_NAME));
            }
        }
        return "N/A";
    }

