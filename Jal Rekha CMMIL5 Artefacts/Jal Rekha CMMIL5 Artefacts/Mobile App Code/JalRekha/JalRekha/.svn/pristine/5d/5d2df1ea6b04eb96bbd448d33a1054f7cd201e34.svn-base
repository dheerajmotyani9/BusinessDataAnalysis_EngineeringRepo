    public void ADD_ISA_VILLAGE(@NonNull IsaInfo isaInfo) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(S_SOURCE, "ISA_VILLAGE");
        contentValues.put(S_KEY, isaInfo.getVillageId());
        contentValues.put(S_NAME, isaInfo.getVillage());
        contentValues.put(S_EXTRA1, isaInfo.getPiuId());
        contentValues.put(S_EXTRA2, isaInfo.getPiu());
        contentValues.put(S_EXTRA3, isaInfo.getSchemeId());
        contentValues.put(S_EXTRA4, isaInfo.getScheme());
        contentValues.put(S_EXTRA5, isaInfo.getBlockId());
        contentValues.put(S_EXTRA6, isaInfo.getBlock());
        contentValues.put(S_EXTRA7, isaInfo.getGpId());
        contentValues.put(S_EXTRA8, isaInfo.getGp());
        db.insert(T_SPINNER, null, contentValues);
    }

    @Nullable
    public IsaInfo getISAInfo() {
        try (Cursor cursor = db.rawQuery("SELECT DISTINCT " + S_EXTRA1 + "," + S_EXTRA2 + "," + S_EXTRA3 + "," + S_EXTRA4 + "," + S_EXTRA5 + "," + S_EXTRA6 + " FROM " + T_SPINNER + " WHERE " + S_SOURCE + "='ISA_VILLAGE'", null)) {
            if (cursor.moveToNext()) {
                return new IsaInfo(cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA1)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA2)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA3)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA4)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA5)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA6)), "", "", "", "");
            }
        }
        return null;
    }

