    public void ADD_COMPONENT_AM(@NonNull SpinnerItem spinnerItem, @NonNull String scheme_id) {
//        this.spinner(spinnerItem, "COMPONENT", scheme_id);
        ContentValues contentValues = new ContentValues();
        contentValues.put(S_KEY, spinnerItem.getKeyString());
        contentValues.put(S_NAME, spinnerItem.getValue());
        contentValues.put(S_SOURCE, "COMPONENT");
        contentValues.put(S_EXTRA1, scheme_id);
        Component component = (Component) spinnerItem.getExtra();
        contentValues.put(S_EXTRA2, component.getHead());
        contentValues.put(S_EXTRA3, component.getLayer());
        contentValues.put(S_EXTRA4, component.getType());
        db.insert(T_SPINNER, null, contentValues);
    }

    public void ADD_COMPONENT_DI_NEW(@NonNull SpinnerItem spinnerItem, @NonNull String scheme_id) {
//        this.spinner(spinnerItem, "COMPONENT_DI", scheme_id);
        ContentValues contentValues = new ContentValues();
        contentValues.put(S_KEY, spinnerItem.getKeyString());
        contentValues.put(S_NAME, spinnerItem.getValue());
        contentValues.put(S_SOURCE, "COMPONENT_DI");
        contentValues.put(S_EXTRA1, scheme_id);
        Component component = (Component) spinnerItem.getExtra();
        contentValues.put(S_EXTRA2, component.getHead());
        contentValues.put(S_EXTRA3, component.getLayer());
        contentValues.put(S_EXTRA4, component.getType());
        db.insert(T_SPINNER, null, contentValues);
    }

    public String ADD_COMPONENT_QUERY(@NonNull SpinnerItem spinnerItem, @NonNull String scheme_id, int i) {
        Component component = (Component) spinnerItem.getExtra();
        StringBuilder sb = new StringBuilder();
        if (i == 0) {
            sb.append("INSERT INTO " + T_SPINNER + "(" + S_KEY + "," + S_NAME + "," + S_SOURCE + "," + S_EXTRA1 + "," + S_EXTRA2 + "," + S_EXTRA3 + "," + S_EXTRA4 + ") VALUES ");
        } else {
            sb.append(",");
        }
        sb.append("('").append(spinnerItem.getKeyString().replace("'", " ")).append("','").append(spinnerItem.getValue().replace("'", " ")).append("','COMPONENT','").append(scheme_id).append("','").append(component.getHead()).append("','").append(component.getLayer()).append("','").append(component.getType()).append("')");
        return sb.toString();
    }


    public void addDailyInspection(boolean old, @NonNull String village, @NonNull String gp, @NonNull String block, @NonNull String detail, @NonNull String comment, @NonNull LatLng latLng, @NonNull String address, @NonNull SpinnerItem piu, @NonNull SpinnerItem scheme, @NonNull SpinnerItem component, @NonNull SpinnerItem app_type, @NonNull SpinnerItem review, @NonNull List<String> images, @NonNull Context context) throws Exception {
        ContentValues contentValues = new ContentValues();

        contentValues.put(D_PIU_ID, piu.getKeyString());
        contentValues.put(D_PIU_NAME, piu.getValue());

        contentValues.put(ALL_SCHEME_ID, scheme.getKeyString());
        contentValues.put(ALL_SCHEME_NAME, scheme.getValue());

        contentValues.put(ALL_COMPONENT_ID, component.getKeyString());
        contentValues.put(ALL_COMPONENT_NAME, component.getValue());

        contentValues.put(D_VILLAGE_NAME, village);
        contentValues.put(D_GP, gp);
        contentValues.put(D_BLOCK, block);

        contentValues.put(D_APP_TYPE_ID, app_type.getKeyString());
        contentValues.put(D_APP_TYPE_NAME, app_type.getValue());

        contentValues.put(D_DETAIL, detail);
        contentValues.put(D_COMMENT, comment);

        contentValues.put(ALL_LAT, latLng.latitude);
        contentValues.put(ALL_LNG, latLng.longitude);
        contentValues.put(D_ADDRESS, address);

        contentValues.put(D_REVIEW_ID, review.getKeyString());
        contentValues.put(D_REVIEW_NAME, review.getValue());


        contentValues.put(ALL_UPLOADED, old ? 1 : 0);

        long id = db.insert(T_DAILY_INSPECTION, null, contentValues);
        if (id == -1) {
            throw new Exception("Something is wrong.");
        }
        for (String image : images) {
            saveBase64(id, image, T_DAILY_INSPECTION, context, (success, jsonArray, base64) -> {

            });
//            ContentValues cv = new ContentValues();
//            cv.put(ALL_SERIAL, id);
//            cv.put(S_NAME, image);
//            cv.put(S_EXTRA1, T_DAILY_INSPECTION);
//            db.insert(T_PHOTO, null, cv);
        }
    }

    @NonNull
    public List<DI> getDailyInspection() {
        List<DI> dis = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_DAILY_INSPECTION + " ORDER BY " + ALL_UPLOADED, null)) {// ORDER BY S_NAME
            while (cursor.moveToNext()) {
                dis.add(new DI(cursor.getLong(cursor.getColumnIndexOrThrow(ALL_SERIAL)), cursor.getString(cursor.getColumnIndexOrThrow(D_ADDRESS)), cursor.getString(cursor.getColumnIndexOrThrow(D_VILLAGE_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(D_GP)), cursor.getString(cursor.getColumnIndexOrThrow(D_BLOCK)), cursor.getString(cursor.getColumnIndexOrThrow(D_DETAIL)), cursor.getString(cursor.getColumnIndexOrThrow(D_APP_TYPE_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_SCHEME_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(D_PIU_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(ALL_COMPONENT_NAME)), cursor.getString(cursor.getColumnIndexOrThrow(D_COMMENT)), cursor.getString(cursor.getColumnIndexOrThrow(D_REVIEW_NAME)), "", cursor.getInt(cursor.getColumnIndexOrThrow(ALL_UPLOADED)) == 1));
            }
        }
        return dis;
    }


    public void getDIObject(@NonNull String token, long id, @NonNull Context context, @NonNull OnDataReceived<Data> onDataReceived) {
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_DAILY_INSPECTION + " WHERE " + ALL_SERIAL + " = '" + id + "'", null)) {// ORDER BY S_NAME
            if (cursor.moveToNext()) {
                final Data data = new Data();
                data.put("etokens", token);
                data.put("piu_id", cursor.getString(cursor.getColumnIndexOrThrow(D_PIU_ID)));
                data.put("scheme_id", cursor.getString(cursor.getColumnIndexOrThrow(ALL_SCHEME_ID)));
                data.put("component_id", cursor.getString(cursor.getColumnIndexOrThrow(ALL_COMPONENT_ID)));
                data.put("village_name", cursor.getString(cursor.getColumnIndexOrThrow(D_VILLAGE_NAME)));
                data.put("block_name", cursor.getString(cursor.getColumnIndexOrThrow(D_BLOCK)));
                data.put("gp_name", cursor.getString(cursor.getColumnIndexOrThrow(D_GP)));
                data.put("application_type_id", cursor.getString(cursor.getColumnIndexOrThrow(D_APP_TYPE_ID)));
                data.put("description", cursor.getString(cursor.getColumnIndexOrThrow(D_DETAIL)));
                data.put("qa_qc_review", cursor.getString(cursor.getColumnIndexOrThrow(D_REVIEW_ID)));
                data.put("qa_qc_remark", cursor.getString(cursor.getColumnIndexOrThrow(D_COMMENT)));
                data.put("latitude", cursor.getString(cursor.getColumnIndexOrThrow(ALL_LAT)));
                data.put("longitude", cursor.getString(cursor.getColumnIndexOrThrow(ALL_LNG)));
                data.put("address", cursor.getString(cursor.getColumnIndexOrThrow(D_ADDRESS)));
                getBase64(id, T_DAILY_INSPECTION, context, (success, jsonArray, base64) -> {
                    if (success) {
                        jsonArray = new JSONArray();
                    }
                    data.put("image_base64", jsonArray);
                    onDataReceived.get(true, data);
                });
//                JSONArray jsonArray = new JSONArray();
//                try (Cursor c2 = db.rawQuery("SELECT * FROM " + T_PHOTO + " WHERE " + ALL_SERIAL + " = '" + id + "' AND " + S_EXTRA1 + "='" + T_DAILY_INSPECTION + "'", null)) {// ORDER BY S_NAME
//                    while (c2.moveToNext()) {
//                        jsonArray.put(c2.getString(c2.getColumnIndexOrThrow(S_NAME)));
//                    }
//                }
            } else {
                onDataReceived.get(false, null);
            }
        }
    }

