    @Override
    public void onCreate(@NonNull SQLiteDatabase db) {
        db.execSQL("CREATE TABLE " + T_LOGIN + "(" + L_USER_ID + " INTEGER," + L_ROLE_ID + " INTEGER," + L_NAME + " VARCHAR," + L_EMAIL + " VARCHAR," + L_MOBILE + " VARCHAR," + L_DISTRICT + " VARCHAR," + L_DESIGNATION + " VARCHAR," + L_ROLE + " VARCHAR," + L_MODULE + " VARCHAR," + L_TOKEN + " VARCHAR);");///," + L_DID + " VARCHAR
        db.execSQL("CREATE TABLE " + T_ASSERT + "(" + ALL_IMEI + " VARCHAR," + ALL_SERIAL + " INTEGER PRIMARY KEY AUTOINCREMENT," + AA_PAST_POINT_ID + " VARCHAR," + ALL_LINE_JSON + " VARCHAR," + ALL_SCHEME_ID + " VARCHAR," + ALL_SCHEME_NAME + " VARCHAR," + ALL_ESR_ID + " VARCHAR," + ALL_ESR_NAME + " VARCHAR," + ALL_POINT_ID + " VARCHAR," + ALL_POINT_NAME + " VARCHAR," + ALL_COMPONENT_ID + " VARCHAR," + ALL_COMPONENT_NAME + " VARCHAR," + ALL_LAT + " VARCHAR," + ALL_LNG + " VARCHAR," + A_REMARK + " VARCHAR," + A_PHOTO + " VARCHAR," + AA_DATE + " VARCHAR," + ALL_DEPTH_COVER + " VARCHAR," + ALL_DIAMETER + " VARCHAR," + ALL_MATERIAL + " VARCHAR," + ALL_ALIGNMENT + " VARCHAR," + ALL_MATERIAL_INFO_NAME + " VARCHAR," + ALL_MATERIAL_INFO_VALUE + " VARCHAR," + ALL_UPLOADED + " INTEGER);");

        db.execSQL("CREATE TABLE " + T_SPINNER + "(" + S_KEY + " VARCHAR," + S_NAME + " VARCHAR," + S_EXTRA1 + " VARCHAR," + S_EXTRA2 + " VARCHAR," + S_EXTRA3 + " VARCHAR," + S_EXTRA4 + " VARCHAR," + S_EXTRA5 + " VARCHAR," + S_EXTRA6 + " VARCHAR," + S_EXTRA7 + " VARCHAR," + S_EXTRA8 + " VARCHAR," + S_EXTRA9 + " VARCHAR," + S_EXTRA10 + " VARCHAR," + S_EXTRA11 + " VARCHAR," + S_EXTRA12 + " VARCHAR," + S_EXTRA13 + " VARCHAR," + S_EXTRA14 + " VARCHAR," + S_EXTRA15 + " VARCHAR," + S_EXTRA16 + " VARCHAR," + S_EXTRA17 + " VARCHAR," + S_EXTRA18 + " VARCHAR," + S_EXTRA19 + " VARCHAR," + S_EXTRA20 + " VARCHAR," + S_SOURCE + " VARCHAR);");
        db.execSQL("CREATE TABLE " + T_LAST_SYNC + "(" + S_KEY + " VARCHAR," + S_NAME + " VARCHAR," + S_EXTRA1 + " VARCHAR);");

        db.execSQL("CREATE TABLE " + T_DAILY_INSPECTION + "(" + ALL_SERIAL + " INTEGER PRIMARY KEY AUTOINCREMENT," + D_PIU_ID + " VARCHAR," + D_PIU_NAME + " VARCHAR," + ALL_SCHEME_ID + " VARCHAR," + ALL_SCHEME_NAME + " VARCHAR," + ALL_COMPONENT_ID + " VARCHAR," + ALL_COMPONENT_NAME + " VARCHAR," + D_VILLAGE_NAME + " VARCHAR," + D_GP + " VARCHAR," + D_BLOCK + " VARCHAR," + D_APP_TYPE_ID + " VARCHAR," + D_APP_TYPE_NAME + " VARCHAR," + D_DETAIL + " VARCHAR," + D_REVIEW_ID + " VARCHAR," + D_REVIEW_NAME + " VARCHAR," + D_COMMENT + " VARCHAR," + ALL_LAT + " VARCHAR," + ALL_LNG + " VARCHAR," + D_ADDRESS + " VARCHAR," + ALL_UPLOADED + " INTEGER);");
        db.execSQL("CREATE TABLE " + T_ISA_ACTIVITY + "(" + ALL_SERIAL + " INTEGER PRIMARY KEY AUTOINCREMENT," + N_GP_ID + " VARCHAR," + N_GP_NAME + " VARCHAR," + N_VILLAGE_ID + " VARCHAR," + N_VILLAGE_NAME + " VARCHAR," + N_ACTIVITY_ID + " VARCHAR," + N_ACTIVITY_NAME + " VARCHAR," + N_REMARK + " VARCHAR," + N_DATE_O_A + " VARCHAR," + N_DATE + " VARCHAR," + N_IS_OLD + " INTEGER," + ALL_LAT + " VARCHAR," + ALL_LNG + " VARCHAR," + ALL_ADDRESS + " VARCHAR," + ALL_UPLOADED + " INTEGER);");
        db.execSQL("CREATE TABLE " + T_PHOTO_NEW + "(" + ALL_SERIAL + " INTEGER," + S_NAME + " VARCHAR," + S_EXTRA1 + " VARCHAR," + S_EXTRA2 + " VARCHAR);");
        db.execSQL("CREATE TABLE " + T_DHARA + "(" + ALL_SERIAL + " INTEGER PRIMARY KEY AUTOINCREMENT," + DH_MAPPING_ID + " VARCHAR," + DH_TYPE_ID + " INTEGER," + DH_TYPE_NAME + " VARCHAR," + DH_MAIN_ID + " INTEGER," + DH_LGD + " VARCHAR," + DH_VILLAGE + " VARCHAR," + DH_METER_ID + " INTEGER," + DH_START_READING + " REAL," + DH_END_READING + " REAL," + DH_END_REMARK + " VARCHAR," + DH_END_LAT + " VARCHAR," + DH_END_LNG + " VARCHAR," + DH_END_DATE + " VARCHAR," + DH_END_TIME + " VARCHAR," + DH_METER_STATUS_ID + " INTEGER," + DH_METER_STATUS_NAME + " VARCHAR," + DH_TOTAL_WS + " REAL);");

        db.execSQL("CREATE TABLE " + T_DHARA_COMPONENT + "(" + DC_ID + " INTEGER," + DC_NAME + " VARCHAR," + DC_TYPE + " INTEGER," + ALL_SCHEME_ID + " INTEGER," + ALL_SCHEME_NAME + " VARCHAR," + DC_WTP_ID + " INTEGER," + ALL_ESR_ID + " VARCHAR," + ALL_ESR_NAME + " VARCHAR," + ALL_ESR_SUID + " VARCHAR," + DC_B_ID + " INTEGER," + DC_B_NAME + " VARCHAR," + DC_METER_ID + " INTEGER," + DC_METER_NAME + " VARCHAR," + DC_R1 + " REAL," + DC_R2 + " REAL," + DC_WS + " REAL," + DC_REMARK + " VARCHAR," + DC_PHOTO + " VARCHAR," + DC_R1_DATE + " VARCHAR," + DC_DATE + " VARCHAR," + ALL_LAT + " VARCHAR," + ALL_LNG + " VARCHAR," + DC_METER_STATUS_ID + " INTEGER," + DC_METER_STATUS_NAME + " VARCHAR);");
        this.db = db;
    }

    @Override
    public void onUpgrade(SQLiteDatabase db, int oldVersion, int newVersion) {
        try {
            if (oldVersion == 1 && newVersion >= 2) {
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA10 + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA11 + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA12 + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA13 + " VARCHAR");
            }
            if (oldVersion <= 2 && newVersion >= 3) {
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA14 + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA15 + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA16 + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA17 + " VARCHAR");
                db.execSQL("CREATE TABLE " + T_DHARA + "(" + ALL_SERIAL + " INTEGER PRIMARY KEY AUTOINCREMENT," + DH_MAPPING_ID + " INTEGER," + DH_TYPE_ID + " INTEGER," + DH_TYPE_NAME + " VARCHAR," + DH_MAIN_ID + " INTEGER," + DH_LGD + " VARCHAR," + DH_VILLAGE + " VARCHAR," + DH_METER_ID + " INTEGER," + DH_START_READING + " REAL," + DH_END_READING + " REAL," + DH_END_REMARK + " VARCHAR," + DH_END_LAT + " VARCHAR," + DH_END_LNG + " VARCHAR," + DH_END_DATE + " VARCHAR," + DH_END_TIME + " VARCHAR);");
            }
            if (oldVersion <= 3 && newVersion == 4) {
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA18 + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA19 + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA20 + " VARCHAR");
            }

            if (oldVersion <= 4 && newVersion == 5) {
                db.execSQL("ALTER TABLE " + T_DHARA + " ADD COLUMN " + DH_METER_STATUS_ID + " INTEGER");
                db.execSQL("ALTER TABLE " + T_DHARA + " ADD COLUMN " + DH_METER_STATUS_NAME + " VARCHAR");
                db.execSQL("ALTER TABLE " + T_DHARA + " ADD COLUMN " + DH_TOTAL_WS + " REAL");

                db.execSQL("CREATE TABLE " + T_DHARA_COMPONENT + "(" + DC_ID + " INTEGER," + DC_NAME + " VARCHAR," + DC_TYPE + " INTEGER," + ALL_SCHEME_ID + " INTEGER," + ALL_SCHEME_NAME + " VARCHAR," + DC_WTP_ID + " INTEGER," + ALL_ESR_ID + " VARCHAR," + ALL_ESR_NAME + " VARCHAR," + DC_B_ID + " INTEGER," + DC_B_NAME + " VARCHAR," + DC_METER_ID + " INTEGER," + DC_METER_NAME + " VARCHAR," + DC_R1 + " REAL," + DC_R2 + " REAL," + DC_WS + " REAL," + DC_REMARK + " VARCHAR," + DC_PHOTO + " VARCHAR," + DC_R1_DATE + " VARCHAR," + DC_DATE + " VARCHAR," + ALL_LAT + " VARCHAR," + ALL_LNG + " VARCHAR," + DC_METER_STATUS_ID + " INTEGER," + DC_METER_STATUS_NAME + " VARCHAR);");
            }

            if (oldVersion <= 5 && newVersion == 6) {
                db.execSQL("ALTER TABLE " + T_DHARA_COMPONENT + " ADD COLUMN " + ALL_ESR_SUID + " VARCHAR");
            }
        } catch (Exception ignore) {

        }
//        if (oldVersion == 1 && newVersion == 2) {
//            db.execSQL("ALTER TABLE " + T_LOGIN + " ADD COLUMN " + L_TOKEN + " VARCHAR");
////            db.execSQL("ALTER TABLE " + T_ASSERT + " ADD COLUMN " + ALL_MATERIAL_INFO_VALUE + " VARCHAR");
//
//            db.execSQL("CREATE TABLE " + T_DAILY_INSPECTION + "(" + ALL_SERIAL + " INTEGER PRIMARY KEY AUTOINCREMENT," + D_PIU_ID + " VARCHAR," + D_PIU_NAME + " VARCHAR," + ALL_SCHEME_ID + " VARCHAR," + ALL_SCHEME_NAME + " VARCHAR," + ALL_COMPONENT_ID + " VARCHAR," + ALL_COMPONENT_NAME + " VARCHAR," + D_VILLAGE_NAME + " VARCHAR," + D_GP + " VARCHAR," + D_BLOCK + " VARCHAR," + D_APP_TYPE_ID + " VARCHAR," + D_APP_TYPE_NAME + " VARCHAR," + D_DETAIL + " VARCHAR," + D_REVIEW_ID + " VARCHAR," + D_REVIEW_NAME + " VARCHAR," + D_COMMENT + " VARCHAR," + ALL_LAT + " VARCHAR," + ALL_LNG + " VARCHAR," + D_ADDRESS + " VARCHAR," + ALL_UPLOADED + " INTEGER);");
//            db.execSQL("CREATE TABLE " + T_PHOTO + "(" + ALL_SERIAL + " INTEGER," + S_NAME + " VARCHAR," + S_EXTRA1 + " VARCHAR);");
//        }else if(newVersion == 3){
//            db.execSQL("ALTER TABLE " + T_LOGIN + " ADD COLUMN " + L_USER_ID + " INTEGER");
//            db.execSQL("ALTER TABLE " + T_LOGIN + " ADD COLUMN " + L_ROLE + " VARCHAR");
//            db.execSQL("ALTER TABLE " + T_LOGIN + " ADD COLUMN " + L_ROLE_ID + " INTEGER");
//            db.execSQL("ALTER TABLE " + T_LOGIN + " ADD COLUMN " + L_MODULE + " VARCHAR");
//
//
//            db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA7 + " VARCHAR");
//            db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA8 + " VARCHAR");
//            db.execSQL("ALTER TABLE " + T_SPINNER + " ADD COLUMN " + S_EXTRA9 + " VARCHAR");
//        }
    }

