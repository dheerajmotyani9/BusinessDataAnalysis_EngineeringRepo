    public List<SpinnerItem> GET_COMPONENT_AM(@NonNull String scheme_id, int type) {//1,2,(INT_ALL)
        List<SpinnerItem> spinnerItems = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_SPINNER + " WHERE " + S_SOURCE + "=? AND " + S_EXTRA1 + "=? " + (type == INT_ALL ? "" : "AND " + S_EXTRA4 + "=" + type + " ") + " ORDER BY " + S_NAME, new String[]{"COMPONENT", scheme_id})) {
            while (cursor.moveToNext()) {
                spinnerItems.add(new SpinnerItem(cursor.getString(cursor.getColumnIndexOrThrow(S_KEY)), cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), new Component(cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA2)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA3)), cursor.getInt(cursor.getColumnIndexOrThrow(S_EXTRA4)))));
            }
        }
        return spinnerItems;
    }

    public List<LayerInfo> GET_COMPONENT_ONLY_AM(boolean byDefaultON, @NonNull String scheme_id, int type, String lineId) {//1,2,(INT_ALL)
        List<LayerInfo> layerInfos = new ArrayList<>();
        Component c;
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_SPINNER + " WHERE " + S_SOURCE + "=? AND " + S_EXTRA1 + "=? " + (type == INT_ALL ? "" : "AND " + S_EXTRA4 + "=" + type + " ") + " ORDER BY " + S_NAME, new String[]{"COMPONENT", scheme_id})) {
            while (cursor.moveToNext()) {
                String id = cursor.getString(cursor.getColumnIndexOrThrow(S_KEY));
                c = new Component(cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA2)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA3)), cursor.getInt(cursor.getColumnIndexOrThrow(S_EXTRA4)));
                layerInfos.add(new LayerInfo(id, cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), c, (byDefaultON && (c.getType() == 1 || id.equals(lineId)))));
            }
        }
        return layerInfos;
    }

    @Nullable
    public LayerInfo GET_COMPONENT_ONLY1_AM(@NonNull String scheme_id, String comp_id) {//1,2,(INT_ALL)
        Log.e("QQCC", "S " + scheme_id + " - " + comp_id);
        Component c;
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_SPINNER + " WHERE " + S_SOURCE + "=? AND " + S_EXTRA1 + "=? AND " + S_KEY + "=? ORDER BY " + S_NAME, new String[]{"COMPONENT", scheme_id, comp_id})) {
            if (cursor.moveToNext()) {
                String id = cursor.getString(cursor.getColumnIndexOrThrow(S_KEY));
                c = new Component(cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA2)), cursor.getString(cursor.getColumnIndexOrThrow(S_EXTRA3)), cursor.getInt(cursor.getColumnIndexOrThrow(S_EXTRA4)));
                return new LayerInfo(id, cursor.getString(cursor.getColumnIndexOrThrow(S_NAME)), c, true);
            }
        }
        return null;
    }

