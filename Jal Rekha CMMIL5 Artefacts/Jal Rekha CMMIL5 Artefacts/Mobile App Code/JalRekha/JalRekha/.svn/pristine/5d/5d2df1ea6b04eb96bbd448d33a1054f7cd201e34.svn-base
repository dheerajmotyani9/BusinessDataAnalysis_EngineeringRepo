    public void ADD_ISA(@NonNull ISA isa, @NonNull List<String> documents, @NonNull List<String> images, boolean isOLD, @NonNull Context context) throws Exception {
        ContentValues contentValues = new ContentValues();
        contentValues.put(ALL_UPLOADED, isa.isUploaded() ? 1 : 0);
        contentValues.put(N_GP_ID, isa.getGpId());
        contentValues.put(N_GP_NAME, isa.getGp());
        contentValues.put(N_VILLAGE_ID, isa.getVillageId());
        contentValues.put(N_VILLAGE_NAME, isa.getVillage());
        contentValues.put(N_ACTIVITY_ID, isa.getActivityId());
        contentValues.put(N_ACTIVITY_NAME, isa.getActivity());
        contentValues.put(N_REMARK, isa.getRemark());
        contentValues.put(N_DATE_O_A, isa.getDate());
        contentValues.put(N_DATE, isa.getCapture());
        contentValues.put(N_IS_OLD, isOLD ? 1 : 0);
        contentValues.put(ALL_LAT, isa.getLat());
        contentValues.put(ALL_LNG, isa.getLng());
        contentValues.put(ALL_ADDRESS, isa.getAddress());
//        Log.d("DB_VALUES", contentValues.toString());

        long id = db.insert(T_ISA_ACTIVITY, null, contentValues);
        if (id == -1) {
            throw new Exception("Something is wrong.");
        }
        for (String doc : documents) {
            saveBase64(id, doc, T_ISA_ACTIVITY, PHOTO_FLAG.DOC, context, (success, jsonArray, base64) -> {

            });
        }
        for (String img : images) {
            saveBase64(id, img, T_ISA_ACTIVITY, PHOTO_FLAG.IMG, context, (success, jsonArray, base64) -> {

            });
        }
    }

    public interface OnDataReceived<T> {
        void get(boolean success, @Nullable T data);
    }

    public void GET_ISA(@NonNull String token, long id, @NonNull Context context, @NonNull OnDataReceived<Data> onDataReceived) {
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_ISA_ACTIVITY + " WHERE " + ALL_SERIAL + "=" + id, null)) {// ORDER BY S_NAME
            if (cursor.moveToNext()) {
                final Data data = new Data();
                data.put(Utility.E_TOKEN, token);
                data.put("gp_code", cursor.getString(cursor.getColumnIndexOrThrow(N_GP_ID)));
                data.put("vill_cd", cursor.getString(cursor.getColumnIndexOrThrow(N_VILLAGE_ID)));
                data.put("activity_id", cursor.getString(cursor.getColumnIndexOrThrow(N_ACTIVITY_ID)));
                data.put("remark", cursor.getString(cursor.getColumnIndexOrThrow(N_REMARK)));
                data.put("capture_dt", cursor.getString(cursor.getColumnIndexOrThrow(N_DATE)));
                data.put("activity_dt", cursor.getString(cursor.getColumnIndexOrThrow(N_DATE_O_A)));
                data.put("is_old_activity", cursor.getInt(cursor.getColumnIndexOrThrow(N_IS_OLD)));
                data.put("lat", cursor.getDouble(cursor.getColumnIndexOrThrow(ALL_LAT)));
                data.put("longt", cursor.getDouble(cursor.getColumnIndexOrThrow(ALL_LNG)));
                data.put("address", cursor.getString(cursor.getColumnIndexOrThrow(ALL_ADDRESS)));
                data.put("doc_ext", "pdf");
                getBase64(id, T_ISA_ACTIVITY, PHOTO_FLAG.DOC, context, (success, jsonArray, base64) -> {
                    if (!success) {
                        jsonArray = new JSONArray();
                    }
                    data.put("doc_path", jsonArray);
                    getBase64(id, T_ISA_ACTIVITY, PHOTO_FLAG.IMG, context, (success1, jsonArray1, base641) -> {
                        if (!success1) {
                            jsonArray1 = new JSONArray();
                        }
                        data.put("photo_path", jsonArray1);
                        onDataReceived.get(true, data);
                    });
                });
            } else {
                onDataReceived.get(false, null);
            }
        }
    }

    public void discardISA(long serial, @NonNull Context context) {
        db.delete(T_ISA_ACTIVITY, ALL_SERIAL + "=" + serial, null);
        clearBase64(serial, T_ISA_ACTIVITY, context);
    }

    public void setISAUploaded(long serial) {
        ContentValues contentValues = new ContentValues();
        contentValues.put(ALL_UPLOADED, 1);
        db.update(T_ISA_ACTIVITY, contentValues, ALL_SERIAL + "=" + serial, null);
    }

    @NonNull
    public List<ISA> GET_ISA() {
        List<ISA> isa = new ArrayList<>();
        try (Cursor cursor = db.rawQuery("SELECT * FROM " + T_ISA_ACTIVITY, null)) {// ORDER BY S_NAME
            while (cursor.moveToNext()) {
                long id = cursor.getLong(cursor.getColumnIndexOrThrow(ALL_SERIAL));
                int countD = getBase64Count(id, T_ISA_ACTIVITY, PHOTO_FLAG.DOC);
                int countI = getBase64Count(id, T_ISA_ACTIVITY, PHOTO_FLAG.IMG);
                isa.add(new ISA(
                        id,
                        cursor.getInt(cursor.getColumnIndexOrThrow(ALL_UPLOADED)) == 1,
                        cursor.getString(cursor.getColumnIndexOrThrow(N_GP_ID)),
                        cursor.getString(cursor.getColumnIndexOrThrow(N_GP_NAME)),
                        cursor.getString(cursor.getColumnIndexOrThrow(N_VILLAGE_ID)),
                        cursor.getString(cursor.getColumnIndexOrThrow(N_VILLAGE_NAME)),
                        cursor.getString(cursor.getColumnIndexOrThrow(N_ACTIVITY_ID)),
                        cursor.getString(cursor.getColumnIndexOrThrow(N_ACTIVITY_NAME)),
                        cursor.getString(cursor.getColumnIndexOrThrow(N_REMARK)),
                        cursor.getString(cursor.getColumnIndexOrThrow(N_DATE_O_A)),
                        cursor.getString(cursor.getColumnIndexOrThrow(N_DATE)),
                        cursor.getDouble(cursor.getColumnIndexOrThrow(ALL_LAT)),
                        cursor.getDouble(cursor.getColumnIndexOrThrow(ALL_LNG)),
                        cursor.getString(cursor.getColumnIndexOrThrow(ALL_ADDRESS)),
                        countD > 0,
                        countI > 0
                ));
            }
        }
        return isa;
    }


