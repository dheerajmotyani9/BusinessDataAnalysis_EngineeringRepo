    }

    public interface OnSubmit {
        void success(boolean success, @Nullable JSONArray jsonArray, @Nullable String base64);
    }

    private void saveBase64(long id, @NonNull String base64, @NonNull String table, @NonNull Context context, @NonNull OnSubmit onSubmit) {
        saveBase64(id, base64, table, PHOTO_FLAG.DEFAULT, context, onSubmit);
    }

    private void saveBase64(long id, @NonNull String base64, @NonNull String table, @NonNull PHOTO_FLAG photoFlag, @NonNull Context context, @NonNull OnSubmit onSubmit) {
//        Log.e("ABCD_SB64", "SAVE FILE INIT " + id);
        Utility.saveFileInternal(base64, context, (name, e) -> {
//            Log.e("ABCD_SB64", "SAVE FILE NAME " + name);
            if (name == null) {
                Utility.show(context, e);
                onSubmit.success(false, null, null);
                return;
            }
            ContentValues cv = new ContentValues();
            cv.put(ALL_SERIAL, id);
            cv.put(S_NAME, name);
            cv.put(S_EXTRA1, table);
            cv.put(S_EXTRA2, photoFlag.flag);
            db.insert(T_PHOTO_NEW, null, cv);
            onSubmit.success(true, null, null);
//            Log.e("ABCD_SB64", "SAVE FILE END " + id + " IRC: " + irc);
//            Log.e("ABCD_SB64", cv.toString());
        });
    }


    private void getBase64(long id, @NonNull String table, @NonNull Context context, @NonNull OnSubmit onSubmit) {
        getBase64(id, table, PHOTO_FLAG.DEFAULT, context, onSubmit);
    }


    private void getBase64(long id, @NonNull String table, @NonNull PHOTO_FLAG photoFlag, @NonNull Context context, @NonNull OnSubmit onSubmit) {
        JSONArray jsonArray = new JSONArray();
        try (Cursor c2 = db.rawQuery("SELECT " + S_NAME + " FROM " + T_PHOTO_NEW + " WHERE " + ALL_SERIAL + " = '" + id + "' AND " + S_EXTRA1 + "='" + table + "' AND " + S_EXTRA2 + "='" + photoFlag.flag + "'", null)) {// ORDER BY S_NAME
            final int c = c2.getCount();
            AtomicInteger ic = new AtomicInteger();
            AtomicBoolean atomicBoolean = new AtomicBoolean();
            atomicBoolean.set(true);
            if (c > 0) {
                while (c2.moveToNext()) {
                    if (atomicBoolean.get()) {
                        Utility.readFileInternal(c2.getString(c2.getColumnIndexOrThrow(S_NAME)), context, (name, e) -> {
                            if (name == null) {
                                onSubmit.success(false, null, null);
                                atomicBoolean.set(false);
                                return;
                            }
                            if (atomicBoolean.get()) {
                                jsonArray.put(name);
                                ic.getAndIncrement();
                                if (ic.get() == c) {
                                    if (atomicBoolean.get()) {
                                        onSubmit.success(true, jsonArray, null);
                                    }
                                }
                            }
                        });
                    }
                }
            } else {
                onSubmit.success(true, jsonArray, null);
            }
        }
    }


    private void getBase64(long id, @NonNull String table, @NonNull PHOTO_FLAG photoFlag, int offset, @NonNull Context context, @NonNull OnSubmit onSubmit) {
        try (Cursor c2 = db.rawQuery("SELECT " + S_NAME + " FROM " + T_PHOTO_NEW + " WHERE " + ALL_SERIAL + " = '" + id + "' AND " + S_EXTRA1 + "='" + table + "' AND " + S_EXTRA2 + "='" + photoFlag.flag + "' LIMIT 1 OFFSET " + offset, null)) {// ORDER BY S_NAME
            if (c2.moveToNext()) {
                Utility.readFileInternal(c2.getString(c2.getColumnIndexOrThrow(S_NAME)), context, (name, e) -> {
                    if (name == null) {
                        onSubmit.success(false, null, null);
                    } else {
                        onSubmit.success(true, null, name);
                    }
                });
//                return c2.getString(c2.getColumnIndexOrThrow(S_NAME));
            }
        }
    }


    private int getBase64Count(long id, @NonNull String table, @NonNull PHOTO_FLAG photoFlag) {
        try (Cursor c2 = db.rawQuery("SELECT count(*) as total FROM " + T_PHOTO_NEW + " WHERE " + ALL_SERIAL + " = '" + id + "' AND " + S_EXTRA1 + "='" + table + "' AND " + S_EXTRA2 + "='" + photoFlag.flag + "'", null)) {// ORDER BY S_NAME
            if (c2.moveToNext()) {
                return c2.getInt(c2.getColumnIndexOrThrow("total"));
            }
        }
        return 0;
    }

    private void clearBase64(long id, @NonNull String table, @NonNull Context context) {
        clearBase64(id, table, PHOTO_FLAG.DEFAULT, context);
    }

    private void clearBase64(long id, @NonNull String table, @NonNull PHOTO_FLAG photoFlag, @NonNull Context context) {
//        Log.e("ABCD_CB64", "DELETE FILE INIT " + id);
        try (Cursor c2 = db.rawQuery("SELECT " + S_NAME + " FROM " + T_PHOTO_NEW + " WHERE " + ALL_SERIAL + " = '" + id + "' AND " + S_EXTRA1 + "='" + table + "' AND " + S_EXTRA2 + "='" + photoFlag.flag + "'", null)) {// ORDER BY S_NAME
            if (c2.moveToNext()) {
                String name = c2.getString(c2.getColumnIndexOrThrow(S_NAME));
//                Log.e("ABCD_CB64", "DELETE DRIVE FILE " + name);
                Utility.deleteFileInternal(name, context);
//                return c2.getString(c2.getColumnIndexOrThrow(S_NAME));
            }
        }
        db.delete(T_PHOTO_NEW, ALL_SERIAL + "=" + id + " AND " + S_EXTRA1 + "='" + table + "' AND " + S_EXTRA2 + "='" + photoFlag.flag + "'", null);
//        Log.e("ABCD_CB64", "DELETE FILE END " + id + " NOAR: " + noar);
    }

    public static class PHOTO_FLAG {
        public static final PHOTO_FLAG DEFAULT = new PHOTO_FLAG("");
        public static final PHOTO_FLAG IMG = new PHOTO_FLAG("IMG");
        public static final PHOTO_FLAG DOC = new PHOTO_FLAG("DOC");
        String flag;

        public PHOTO_FLAG(String flag) {
            this.flag = flag;
        }
    }
}
