    public String ADD_POINTS_QUERY(@NonNull SpinnerItem spinnerItem, @NonNull String scheme_id, @NonNull String cid, @NonNull String lgdCode, @NonNull String village, int i) {
        Point point = (Point) spinnerItem.getExtra();
        StringBuilder sb = new StringBuilder();
        if (i % 10000 == 0) {
            sb.append("INSERT INTO " + T_SPINNER + "(" + S_KEY + "," + S_NAME + "," + S_SOURCE + "," + S_EXTRA1 + "," + S_EXTRA2 + "," + S_EXTRA3 + "," + S_EXTRA4 + "," + S_EXTRA5 + "," + S_EXTRA6 + ") VALUES ");
        } else {
            sb.append(",");
        }
        sb.append("('").append(spinnerItem.getKeyString().replace("'", " ")).append("','").append(spinnerItem.getValue().replace("'", " ")).append("','POINTS','").append(scheme_id).append("','").append(cid).append("','").append(point.getLat()).append("','").append(point.getLng()).append("','").append(lgdCode).append("','").append(village.isEmpty() ? "N/A" : village).append("')");
        return sb.toString();
//        ContentValues contentValues = new ContentValues();
