package mapitgis.jalnigam.nirmal.database.dao

import androidx.lifecycle.LiveData
import androidx.room.Dao
import androidx.room.Insert
import androidx.room.OnConflictStrategy
import androidx.room.Query
import mapitgis.jalnigam.nirmal.database.table.NirmalDistBlockVillage


@Dao
interface NirmalDistBlockVillageDao {

    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertVillage(village: NirmalDistBlockVillage)

    @Query("SELECT * FROM nirmal_dist_village WHERE villageCode = :villageCode")
    suspend fun getVillageByCode(villageCode: String): NirmalDistBlockVillage?

    @Query("SELECT * FROM nirmal_dist_village")
    suspend fun getAllVillages(): List<NirmalDistBlockVillage>

    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertAll(villages: List<NirmalDistBlockVillage>)

    @Query("DELETE FROM nirmal_dist_village")
    suspend fun clearTable()



    @Query("""
        SELECT DISTINCT
            villageName,
            villageCode
        FROM 
            nirmal_dist_village 
        WHERE 
            esrCode = :ohsrCode
    """)
    suspend fun getDistinctVillageDetails(ohsrCode: String): List<VillageDetails>

    @Query("""
        SELECT 
            v.villageCode AS villageId,
            v.villageName AS villageName,
            COUNT(q.id) AS count 
        FROM nirmal_dist_village v
        LEFT JOIN nirmal_quality_monitoring q 
            ON v.villageCode = q.villageId 
            AND q.assignedSurveyId = :assignedSurveyId
            AND q.uploaded = :status
        WHERE v.esrCode = :ohsrCode
        GROUP BY v.villageCode, v.villageName
    """)
    fun getVillageDetailsWithCount(ohsrCode: String, assignedSurveyId: String,status:Int): LiveData<List<VillageDetailsWithCount>>

}


data class VillageDetails(
    val villageName: String,
    val villageCode: String
){
    override fun toString(): String {
        //return villageName
        return "$villageName - $villageCode"
    }
}


data class VillageDetailsWithCount(
    val villageId: String,
    val villageName: String,
    val count: Int
){
    override fun toString(): String {
        return "${villageName} (${count})"
    }
}
