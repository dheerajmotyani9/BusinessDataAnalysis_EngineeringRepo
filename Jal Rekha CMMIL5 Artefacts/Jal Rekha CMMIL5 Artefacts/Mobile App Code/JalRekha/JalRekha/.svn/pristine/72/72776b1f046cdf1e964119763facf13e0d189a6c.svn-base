package mapitgis.jalnigam.nirmal.screens.viewdetail

import android.annotation.SuppressLint
import android.content.Context
import android.content.Intent
import android.location.Location
import android.net.Uri
import android.os.Bundle
import androidx.activity.viewModels
import androidx.core.util.component1
import androidx.lifecycle.ViewModelProvider
import com.google.android.gms.maps.CameraUpdateFactory
import com.google.android.gms.maps.GoogleMap
import com.google.android.gms.maps.OnMapReadyCallback
import com.google.android.gms.maps.SupportMapFragment
import com.google.android.gms.maps.model.LatLng
import mapitgis.jalnigam.BaseActivity
import mapitgis.jalnigam.R
import mapitgis.jalnigam.core.Utility
import mapitgis.jalnigam.databinding.ActivityNirmalWqmdetailsBinding
import mapitgis.jalnigam.nirmal.camera.ViewImageActivity
import mapitgis.jalnigam.nirmal.database.table.NirmalWQMEntity

class WQMDetailsActivity : BaseActivity(), OnMapReadyCallback {

    private lateinit var googleMap: GoogleMap

    companion object{
        fun pushActivity(context: Context,detail: NirmalWQMEntity){
            context.startActivity(Intent(context, WQMDetailsActivity::class.java).apply {
                setFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                putExtra("survey_detail", detail)
            })
        }
    }

    private val binding: ActivityNirmalWqmdetailsBinding by lazy {
        ActivityNirmalWqmdetailsBinding.inflate(layoutInflater)
    }

    private val viewModel: WQMDetailsVM by viewModels {
        ViewModelProvider.AndroidViewModelFactory.getInstance(application)
    }


    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(binding.root)
        setupToolbar()
        initView()
        binding.lifecycleOwner = this
        binding.viewModel = viewModel
        viewModel.fetchValueFromIntent(intent)
        setupMap()
    }

    private fun setupMap(){
        val mapFragment = supportFragmentManager.findFragmentById(R.id.map) as SupportMapFragment
        mapFragment.getMapAsync(this)
    }

    private fun initView(){
        binding.sampleImg.setOnClickListener {
            ViewImageActivity.viewImage(baseContext,viewModel.surveyDetail.sampleImgFilePath)
        }

        binding.frcImage.setOnClickListener {
            ViewImageActivity.viewImage(baseContext,viewModel.surveyDetail.frcImgFilePath)
        }
    }

    private fun setupToolbar(){
        setSupportActionBar(binding.appbar.toolbar)
        supportActionBar?.setDisplayHomeAsUpEnabled(true)
        supportActionBar?.title = "Details"
    }

    @SuppressLint("MissingPermission")
    override fun onMapReady(map: GoogleMap) {
        googleMap = map
        googleMap.mapType = GoogleMap.MAP_TYPE_SATELLITE
        showLocationOnMap()
    }

    private fun showLocationOnMap(){
        val latLng = LatLng(viewModel.surveyDetail.latitude, viewModel.surveyDetail.longitude)
        googleMap.moveCamera(CameraUpdateFactory.newLatLng(latLng))
        googleMap.animateCamera(CameraUpdateFactory.zoomTo(18f))
        viewModel.getLatLngAddress(baseContext)
    }
}