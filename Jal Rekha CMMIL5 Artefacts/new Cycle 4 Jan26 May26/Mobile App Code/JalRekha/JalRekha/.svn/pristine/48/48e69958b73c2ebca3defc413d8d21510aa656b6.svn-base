<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <LinearLayout
        android:id="@+id/pipeline_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!--OHT Layout-->
        <TextView
            android:id="@+id/tv_lbl_oht_mbr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/oht_name"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_select_oht_mbr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/rect_line_shape"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp"
            android:text="Select OHT"
            android:textColor="@color/black"
            app:drawableEndCompat="@drawable/ic_arrow_drop_down"/>



        <!--Pipe Number-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/pipe_no"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_select_pipe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/rect_line_shape"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp"
            android:text="Select Pipe No"
            android:textColor="@color/black"
            app:drawableEndCompat="@drawable/ic_arrow_drop_down"/>

        <LinearLayout
            android:id="@+id/layout_pipe_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp">




            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rect_line_shape"
                android:orientation="vertical"
                android:padding="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.app.viewcomponent.FormKeyValueText
                        android:id="@+id/tv_pipeno"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:key="Pipe No"
                        android:padding="4dp"
                        app:weights="0,0"
                        />

                    <com.app.viewcomponent.FormKeyValueText
                        android:id="@+id/tv_class"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:key="Class"
                        android:padding="4dp"
                        app:weights="0,0"
                        />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray_1"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.app.viewcomponent.FormKeyValueText
                        android:id="@+id/tv_startno"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:key="Start No"
                        android:padding="4dp"
                        app:weights="0,0"
                        />



                    <com.app.viewcomponent.FormKeyValueText
                        android:id="@+id/tv_stop_no"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:key="Stop No"
                        android:padding="4dp"
                        app:weights="0,0"
                        />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray_1"/>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.app.viewcomponent.FormKeyValueText
                        android:id="@+id/tv_diameter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:key="Diameter"
                        android:padding="4dp"
                        app:weights="0,0"
                        />



                    <com.app.viewcomponent.FormKeyValueText
                        android:id="@+id/tv_length"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:key="Length"
                        android:padding="4dp"
                        app:weights="0,0"
                        />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray_1"/>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.app.viewcomponent.FormKeyValueText
                        android:id="@+id/tv_material"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:key="Material"
                        android:padding="4dp"
                        app:weights="0,0"
                        />



                    <com.app.viewcomponent.FormKeyValueText
                        android:id="@+id/tv_thickness"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:key="Thickness"
                        android:padding="4dp"
                        app:weights="0,0"
                        />

                </LinearLayout>

            </LinearLayout>


            <!--Inbetween length-->
            <TextView
                android:id="@+id/lbl_inbetween_length"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/pipe_inbetween_length"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/select_inbetween_length"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@drawable/rect_line_shape"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:text="Select"
                android:textColor="@color/black"
                app:drawableEndCompat="@drawable/ic_arrow_drop_down" />


        </LinearLayout>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>