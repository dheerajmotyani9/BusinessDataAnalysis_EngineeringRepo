package mapitgis.jalnigam.nirmal.location

import android.content.BroadcastReceiver
import android.content.Context
import android.content.Intent
import androidx.localbroadcastmanager.content.LocalBroadcastManager
import com.google.android.gms.location.GeofencingEvent


class GeofenceBroadcastReceiver : BroadcastReceiver() {

    override fun onReceive(context: Context, intent: Intent?) {
        if (intent == null) return

        val geofencingEvent = GeofencingEvent.fromIntent(intent)
        if (geofencingEvent == null || geofencingEvent.hasError()) return

        val transitionType = geofencingEvent.geofenceTransition
        val triggeringGeofences = geofencingEvent.triggeringGeofences

        if (triggeringGeofences.isNullOrEmpty()) return // Ensure there is at least one geofence

        val geofenceId = triggeringGeofences.firstOrNull()?.requestId ?: "Unknown Geofence"

        // Send a local broadcast with geofence transition data
        val localIntent = Intent(GeofenceUtil.GEOFENCE_ACTION).apply {
            putExtra(GeofenceUtil.EXTRA_TRANSITION_TYPE, transitionType)
            putExtra(GeofenceUtil.GEOFENCE_ID, geofenceId)
        }
        LocalBroadcastManager.getInstance(context).sendBroadcast(localIntent)
    }
}
