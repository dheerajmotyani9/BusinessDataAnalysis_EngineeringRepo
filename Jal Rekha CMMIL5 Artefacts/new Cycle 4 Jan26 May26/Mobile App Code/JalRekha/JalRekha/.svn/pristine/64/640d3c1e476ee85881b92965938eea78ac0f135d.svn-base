<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="15dp"
    android:paddingEnd="15dp"
    android:paddingTop="10dp"
    android:layout_marginBottom="10dp"
    android:background="@color/white"
    android:id="@+id/layout_inspection_history_main_container"
    android:orientation="vertical">


    <TextView
        android:id="@+id/layout_inspection_history_message_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:visibility="gone"
        android:textStyle="bold"
        android:textSize="12sp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="@drawable/failed_button_shape"/>

    <LinearLayout
        android:id="@+id/layout_inspection_history_first_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request id"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_req_id_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="789465"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request Date"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_req_date_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21-02-2024"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_status_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:gravity="end"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/layout_inspection_first_line_view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="@dimen/dp5"
        android:background="@color/redLightColor"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scheme"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/layout_inspection_history_scheme_name_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pahadgarh"
            android:textSize="12sp"
            android:textColor="@color/black"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/dp2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Component Type"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_comp_type_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intake well"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_inspection_point_container"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Point Name"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_point_name_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intake well"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_inspection_stage_container"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:gravity="end"
            android:orientation="vertical"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stage Name"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_stage_name_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_inspection_desc_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="@dimen/dp5"
            android:background="@color/redLightColor"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description of inspection activity"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/layout_inspection_history_description_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="testing description"
            android:textSize="12sp"
            android:textColor="@color/black"/>

    </LinearLayout>

    <View
        android:id="@+id/layout_inspection_third_line_view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="@dimen/dp5"
        android:background="@color/redLightColor"/>
    <LinearLayout
        android:id="@+id/layout_inspection_history_fe_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FE Name"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_f_e_name_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Testing name"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_location_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bhopal"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inspection date"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/layout_inspection_history_ins_date_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12-02-2023"
                android:textSize="12sp"
                android:textColor="@color/black"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:layout_gravity="center">

        <Button
            android:id="@+id/layout_inspection_history_revisit_req_btn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="35dp"
            android:text="Revisit Request"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginBottom="2dp"
            android:background="@drawable/failed_button_shape"/>

        <Button
            android:id="@+id/layout_inspection_history_reschedule_btn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="35dp"
            android:text="Re-Schedule"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:visibility="gone"
            android:layout_marginBottom="2dp"
            android:background="@drawable/failed_button_shape"/>
        <Button
            android:id="@+id/layout_inspection_history_view_detail_btn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="35dp"
            android:text="View Detail"
            android:layout_marginStart="15dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"
            android:textAllCaps="false"
            android:background="@drawable/button_shape"/>

        <Button
            android:id="@+id/layout_inspection_history_view_logs_btn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="35dp"
            android:text="View Logs"
            android:layout_marginStart="15dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"
            android:textAllCaps="false"
            android:background="@drawable/pending_button_shape"/>
    </LinearLayout>

</LinearLayout>