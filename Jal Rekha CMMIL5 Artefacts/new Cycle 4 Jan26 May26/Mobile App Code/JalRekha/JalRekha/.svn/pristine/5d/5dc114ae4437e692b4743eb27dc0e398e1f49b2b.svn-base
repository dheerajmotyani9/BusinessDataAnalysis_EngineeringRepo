package mapitgis.jalnigam.dhara1;

import android.annotation.SuppressLint;
import android.content.Context;
import android.content.res.ColorStateList;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;

import androidx.annotation.NonNull;
import androidx.recyclerview.widget.RecyclerView;

import java.util.ArrayList;
import java.util.List;
import java.util.Locale;

import mapitgis.jalnigam.R;
import mapitgis.jalnigam.core.Utility;
import mapitgis.jalnigam.databinding.AdapterDharaComponentBinding;


public abstract class DharaComponentAdapter extends RecyclerView.Adapter<DharaComponentAdapter.ViewHolder> {
    private final List<DharaComponent> dharaComponentList;
    private final Context context;

    public DharaComponentAdapter(@NonNull Context context) {
        this.dharaComponentList = new ArrayList<>();
        this.context = context;
    }

    @NonNull
    @Override
    public ViewHolder onCreateViewHolder(@NonNull ViewGroup parent, int viewType) {
        return new ViewHolder(AdapterDharaComponentBinding.inflate(LayoutInflater.from(parent.getContext()), parent, false));
    }

    public void clear() {
        int len = this.dharaComponentList.size();
        this.dharaComponentList.clear();
        this.notifyItemRangeRemoved(0, len);
    }

    public void add(DharaComponent dharaComponent) {
        int pos = getItemCount();
        this.dharaComponentList.add(dharaComponent);
        this.notifyItemInserted(pos);
    }

    @Override
    public void onBindViewHolder(@NonNull ViewHolder holder, int position) {
        DharaComponent dharaComponent = dharaComponentList.get(position);
        holder.binding.textViewDate.setText(dharaComponent.getFDate());
        holder.binding.textViewR1.setText(dharaComponent.getR1Reading());
        if (dharaComponent.getR1Date().isEmpty() || dharaComponent.getR2() > 0) {
            holder.binding.textViewR1Date.setVisibility(View.GONE);
            holder.binding.textViewR1Date.setText("");
        } else {
            holder.binding.textViewR1Date.setVisibility(View.VISIBLE);
            holder.binding.textViewR1Date.setText(dharaComponent.getR1DateDetail());
        }
        holder.binding.textViewR2.setText(dharaComponent.getR2Reading());

        if (dharaComponent.getR2() > 0 && dharaComponent.isAllFilled()) {
            holder.binding.buttonDetail.setText(R.string.view_reading);
            holder.binding.imageViewTic.setVisibility(View.VISIBLE);
        } else {
            holder.binding.buttonDetail.setText(R.string.add_reading);
            holder.binding.imageViewTic.setVisibility(View.GONE);
        }

        if (dharaComponent.getR2() > 0) {
            holder.binding.textViewTotalReading.setVisibility(View.VISIBLE);
            holder.binding.textViewTotalReading.setText(Utility.html(String.format("Total Water supply : <font color='blue'><b>%s</b></font> KL", dharaComponent.getTotal())));
        } else {
            holder.binding.textViewTotalReading.setVisibility(View.GONE);
        }

        holder.binding.textViewType.setText(String.format(Locale.UK, "%d. %s", position + 1, dharaComponent.getName()));
        if (dharaComponent.getType() == 3) {
            holder.binding.textViewESR.setVisibility(View.VISIBLE);
            holder.binding.textViewESR.setText(String.format("(%s)", dharaComponent.getEsr()));
        } else if (dharaComponent.getType() == 2 && dharaComponent.getMeterId()>0) {
            holder.binding.textViewESR.setVisibility(View.VISIBLE);
            holder.binding.textViewESR.setText(String.format("(%s)", dharaComponent.getMeter()));
        } else {
            holder.binding.textViewESR.setVisibility(View.INVISIBLE);
            holder.binding.textViewESR.setText("");
        }

        if (dharaComponent.getType() == 4) {
            holder.binding.textViewBeneficiary.setVisibility(View.VISIBLE);
            holder.binding.textViewBeneficiary.setText(String.format("Beneficiary : %s", dharaComponent.getBeneficiary()));
        } else {
            holder.binding.textViewBeneficiary.setVisibility(View.GONE);
            holder.binding.textViewBeneficiary.setText("");
        }

//        if (dharaComponent.getType() == 3) {
//            holder.binding.textViewType.setText(String.format("%s [%s]", dharaComponent.getName(), dharaComponent.getEsr()));
//        } else {
//            holder.binding.textViewType.setText(dharaComponent.getName());
//        }

        holder.binding.textViewType.setTextColor(dharaComponent.getColor(context));
//        holder.binding.imageViewTic.setColorFilter(dharaComponent.getColor(context));
//        holder.binding.card.setCardBackgroundColor(dharaComponent.getColor(context));
        holder.binding.buttonDetail.setBackgroundTintList(ColorStateList.valueOf(dharaComponent.getColor(context)));

//        if (dharaComponent.isUploaded()) {
//            holder.binding.linearLayoutButton.setVisibility(View.GONE);
//        } else {
//            holder.binding.linearLayoutButton.setVisibility(View.VISIBLE);
//        }
    }

    @Override
    public int getItemCount() {
        return dharaComponentList.size();
    }

    @SuppressLint("NotifyDataSetChanged")
    public void addAll(List<DharaComponent> dharaComponentList) {
        this.dharaComponentList.addAll(dharaComponentList);
        this.notifyDataSetChanged();
    }

    @NonNull
    public DharaComponent getItem(int i) {
        return dharaComponentList.get(i);
    }

    public void remove(int pos) {
        this.dharaComponentList.remove(pos);
        this.notifyItemRemoved(pos);
    }

//    public void updateUploaded(int pos) {
//        this.dharaComponentList.get(pos).setUploaded(true);
//        this.notifyItemChanged(pos);
//    }

    public boolean isEmpty() {
        return this.dharaComponentList.isEmpty();
    }

    public class ViewHolder extends RecyclerView.ViewHolder {
        private final AdapterDharaComponentBinding binding;

        public ViewHolder(@NonNull AdapterDharaComponentBinding binding) {
            super(binding.getRoot());
            this.binding = binding;

            binding.buttonDetail.setOnClickListener(v -> {
                int pos = getAdapterPosition();
                onView(pos, dharaComponentList.get(pos));
            });
        }
    }

//    protected abstract void onUpload(int pos,@NonNull DharaComponent dharaComponent);
//
//    protected abstract void onDiscard(int pos,@NonNull DharaComponent dharaComponent);

    protected abstract void onView(int pos, @NonNull DharaComponent dharaComponent);
}
