<?xml version="1.0" encoding="utf-8"?>
<resources>

    <attr name="label" format="string" />
    <attr name="mandatory" format="boolean" />
    <attr name="border" format="boolean" />
    <attr name="radius" format="dimension" />

    <declare-styleable name="FormLabel">
        <attr name="label"/>
        <attr name="mandatory"/>
    </declare-styleable>

    <declare-styleable name="FormKeyValueText">
        <attr name="key" format="string" />
        <attr name="value" format="string" />
        <attr name="valueTextColor" format="color"/>
        <attr name="weights" format="string" />
        <attr name="keyTextSize" format="dimension" />
        <attr name="valueTextSize" format="dimension" />
        <attr name="valueTextStyle" format="enum">
            <enum name="normal" value="0"/>
            <enum name="bold" value="1"/>
            <enum name="italic" value="2"/>
            <enum name="bold_italic" value="3"/>
        </attr>

    </declare-styleable>

    <declare-styleable name="FormEditText">
        <attr name="label"/>
        <attr name="mandatory"/>
        <attr name="radius"/>
        <attr name="border"/>
        <attr name="error" format="string" />
        <attr name="hint" format="string" />
        <attr name="icon" format="reference"/>
        <attr name="android:inputType"/>
        <attr name="android:maxLength"/>
        <attr name="android:singleLine"/>
        <attr name="android:enabled"/>
        <attr name="android:imeOptions"/>
        <attr name="android:lines"/>
        <attr name="android:gravity"/>

    </declare-styleable>

    <declare-styleable name="FormSpinner">
        <attr name="label" />
        <attr name="mandatory"/>
        <attr name="radius"/>
        <attr name="border"/>
    </declare-styleable>

    <declare-styleable name="FormRadio">
        <attr name="label" />
        <attr name="groupOrientation" format="integer"/>
        <attr name="entries" format="string"/>
        <attr name="mandatory"/>
    </declare-styleable>

</resources>