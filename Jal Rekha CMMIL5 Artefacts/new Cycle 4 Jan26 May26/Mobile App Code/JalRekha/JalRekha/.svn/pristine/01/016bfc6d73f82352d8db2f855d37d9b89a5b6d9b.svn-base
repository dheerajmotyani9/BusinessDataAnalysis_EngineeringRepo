    public static void show(@NonNull Context context, @NonNull String title, @NonNull String message, @Nullable String button, @Nullable View.OnClickListener onClickListener, boolean cancelable) {
        AlertDialog.Builder builder = new AlertDialog.Builder(context)
                .setTitle(title)
                .setMessage(message)
                .setCancelable(cancelable);
        if (cancelable) {
            builder.setNegativeButton("Cancel", (dialogInterface, i) -> dialogInterface.dismiss());
        }
        if (button != null) {
            builder.setPositiveButton(button, null);
        }
        AlertDialog alertDialog = builder.create();
        alertDialog.show();
        if (button != null) {
            alertDialog.getButton(DialogInterface.BUTTON_POSITIVE).setOnClickListener(onClickListener);
        }
    }

