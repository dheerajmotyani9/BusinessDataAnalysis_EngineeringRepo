    public static void fillDesignation(@NonNull Activity activity, @NonNull SpinnerListener spinnerListener) {
        List<SpinnerItem> spinnerItemsLocal = SqLite.instance(activity).GET_DESIGNATION();
        spinnerListener.onFill(spinnerItemsLocal, 1);
        new ApiCaller(activity, (response, key) -> {
            try {
                Log.i("AABB", response);
                JSONObject jsonObject = new JSONObject(response);
                if (jsonObject.getBoolean(Utility.SUCCESS)) {
                    JSONArray jsonArray = jsonObject.getJSONArray("Data");
                    JSONObject jsonObject1;
                    List<SpinnerItem> spinnerItems = new ArrayList<>();
                    SqLite.instance(activity).CLEAR_DESIGNATION();
                    for (int i = 0; i < jsonArray.length(); i++) {
                        jsonObject1 = jsonArray.getJSONObject(i);
                        SpinnerItem spinnerItem = new SpinnerItem(jsonObject1.getString("Id"), jsonObject1.getString("Name"));
                        SqLite.instance(activity).ADD_DESIGNATION(spinnerItem);
                        spinnerItems.add(spinnerItem);
                    }
                    spinnerListener.onFill(spinnerItems, 2);
                } else if (!jsonObject.has("internet")) {
                    Utility.show(activity, jsonObject.getString(Utility.MESSAGE));
                }
            } catch (Exception e) {
                Utility.show(activity, e);
            }
        }, 1, "", !spinnerItemsLocal.isEmpty() ? null : activity.getString(R.string.please_wait)).start(API.GetDesignation);
    }


    public static void fillDistrictAM(@NonNull Activity activity, @NonNull SpinnerListener spinnerListener) {
        List<SpinnerItem> spinnerItemsLocal = SqLite.instance(activity).GET_DISTRICT_AM();
        spinnerListener.onFill(spinnerItemsLocal, 1);
        new ApiCaller(activity, (response, key) -> {
            try {

                JSONObject jsonObject = new JSONObject(response);
                if (jsonObject.getBoolean(Utility.SUCCESS)) {
                    JSONArray jsonArray = jsonObject.getJSONArray("Data");
                    JSONObject jsonObject1;
                    List<SpinnerItem> spinnerItems = new ArrayList<>();
                    SqLite.instance(activity).CLEAR_DISTRICT_AM();
                    for (int i = 0; i < jsonArray.length(); i++) {
                        jsonObject1 = jsonArray.getJSONObject(i);
                        SpinnerItem spinnerItem = new SpinnerItem(jsonObject1.getString("DistrictID"), jsonObject1.getString("Name"));
                        SqLite.instance(activity).ADD_DISTRICT_AM(spinnerItem);
                        spinnerItems.add(spinnerItem);
                    }
                    spinnerListener.onFill(spinnerItems, 2);
                } else if (!jsonObject.has("internet")) {
                    Utility.show(activity, jsonObject.getString(Utility.MESSAGE));
                }
            } catch (Exception e) {
                Utility.show(activity, e);
            }
        }, 1, "", !spinnerItemsLocal.isEmpty() ? null : activity.getString(R.string.please_wait)).start(API.GetDistricts);
    }

    public static double distance(@NonNull LatLng latLng, @NonNull LatLng latLng1) {
        Location loc1 = new Location("");
        loc1.setLatitude(latLng.latitude);
        loc1.setLongitude(latLng.longitude);
        Location loc2 = new Location("");
        loc2.setLatitude(latLng1.latitude);
        loc2.setLongitude(latLng1.longitude);
        return loc1.distanceTo(loc2);
//        return (111.111 *
//                Math.toDegrees(Math.acos(Math.min(1.0, Math.cos(Math.toRadians(latLng.latitude))
//                        * Math.cos(Math.toRadians(latLng1.latitude))
//                        * Math.cos(Math.toRadians(latLng.longitude - latLng1.longitude))
//                        + Math.sin(Math.toRadians(latLng.latitude))
//                        * Math.sin(Math.toRadians(latLng1.latitude))))))*1000;
    }

    public static int getIntTag(@NonNull View v, int def) {
        return v.getTag() == null ? def : (int) v.getTag();
    }

    @Nullable
    public static Bitmap bitmap(String base64) {
        Log.e("ABCD_URLP",base64);
        byte[] decodedString = Base64.decode(base64, Base64.DEFAULT);
        return BitmapFactory.decodeByteArray(decodedString, 0, decodedString.length);
    }

    @NonNull
    public static String showDist(double distance) {
        if (distance < 1000) {
            return String.format(Locale.UK, "%.1f M", distance);
        } else {
            return String.format(Locale.UK, "%.3f KM", distance / 1000);
        }
    }


    @NonNull
    public static Bitmap addLatLongToBitmap(@NonNull Bitmap bitmap, double latitude, double longitude, @NonNull String name, @NonNull String mobile) {
        // Create a mutable copy of the bitmap
        Bitmap mutableBitmap = bitmap.copy(Bitmap.Config.ARGB_8888, true);

        // Create a canvas to draw on the bitmap
        Canvas canvas = new Canvas(mutableBitmap);

        // Set up paint for the text
        Paint paint = new Paint();
        paint.setColor(Color.RED); // Text color
        paint.setTextSize(26); // Text size
        paint.setAntiAlias(true); // Smooth edges

        // Format the latitude and longitude
        String[] latLongText1 = {"Latitude", "Longitude", "Date", "Name", "Number"};
        String[] latLongText2 = {String.valueOf(latitude), String.valueOf(longitude), Utility.getCurrentTimeSync(), name, mobile};

        // Choose a position to draw the text (e.g., bottom-left corner)
        int x = 20;
        int y = mutableBitmap.getHeight() - 130;

        String key, value;
        for (int i = 0; i < latLongText1.length; i++) {
            key = latLongText1[i];
            value = latLongText2[i];
            canvas.drawText(key, x, y, paint);
            canvas.drawText(":", x + 120, y, paint);
            canvas.drawText(value, x + 130, y, paint);
            y += 26;
        }

        // Return the modified bitmap
        return mutableBitmap;
    }


    @NonNull
    public static Intent getIntentForCameraFacing(boolean frontFacing) {
        Intent intent = new Intent(MediaStore.ACTION_IMAGE_CAPTURE);
        if (Build.VERSION.SDK_INT < Build.VERSION_CODES.O) {
            if (frontFacing) {
                intent.putExtra("android.intent.extras.CAMERA_FACING", CameraCharacteristics.LENS_FACING_BACK);
            } else {
                intent.putExtra("android.intent.extras.CAMERA_FACING", CameraCharacteristics.LENS_FACING_FRONT);
            }
            // Samsung
            intent.putExtra("camerafacing", "front");
            intent.putExtra("previous_mode", "front");
        } else if (frontFacing) {
            intent.putExtra("android.intent.extras.CAMERA_FACING", CameraCharacteristics.LENS_FACING_BACK);
            intent.putExtra("android.intent.extra.USE_FRONT_CAMERA", true);

            // Samsung
            intent.putExtra("camerafacing", "front");
            intent.putExtra("previous_mode", "front");
        } else {
            intent.putExtra("android.intent.extras.CAMERA_FACING", CameraCharacteristics.LENS_FACING_FRONT);
            intent.putExtra("android.intent.extra.USE_FRONT_CAMERA", false);

            // Samsung
            intent.putExtra("camerafacing", "rear");
            intent.putExtra("previous_mode", "rear");
        }
        return intent;
    }


    @NonNull
    public static Bitmap getImageFromURI(@NonNull Uri uri, @NonNull Context context) {
        String[] filePathColumn = {MediaStore.Images.Media.DATA};
        Cursor cursor = context.getContentResolver().query(uri, filePathColumn, null, null, null);
        assert cursor != null;
        cursor.moveToFirst();
        int index = cursor.getColumnIndex(filePathColumn[0]);
        String picturePath = cursor.getString(index);
        cursor.close();
        return Utility.getResizedBitmap(BitmapFactory.decodeFile(picturePath));
    }

    @NonNull
    public static Bitmap getImageRotation(@NonNull File photoFile) throws Exception {
        Bitmap originalBitmap = BitmapFactory.decodeFile(photoFile.getAbsolutePath());

        // Rotate bitmap if needed
        ExifInterface exifInterface = new ExifInterface(photoFile.getAbsolutePath());
        int orientation = exifInterface.getAttributeInt(ExifInterface.TAG_ORIENTATION, ExifInterface.ORIENTATION_UNDEFINED);
        Bitmap rotatedBitmap = rotateBitmapIfNeeded(originalBitmap, orientation);

        return Utility.getResizedBitmap(rotatedBitmap);
    }

    private static Bitmap rotateBitmapIfNeeded(Bitmap bitmap, int orientation) {
        Matrix matrix = new Matrix();
        switch (orientation) {
            case ExifInterface.ORIENTATION_ROTATE_90:
                matrix.postRotate(90);
                break;
            case ExifInterface.ORIENTATION_ROTATE_180:
                matrix.postRotate(180);
                break;
            case ExifInterface.ORIENTATION_ROTATE_270:
                matrix.postRotate(270);
                break;
            default:
                return bitmap; // No rotation needed
        }
        return Bitmap.createBitmap(bitmap, 0, 0, bitmap.getWidth(), bitmap.getHeight(), matrix, true);
    }

    public static boolean isBase64PdfLessThan5MB(String base64Pdf) {
        if (base64Pdf == null || base64Pdf.isEmpty()) {
            return false; // Handle null or empty input
        }

        // Calculate the size of the Base64 string in bytes
        int base64Length = base64Pdf.length();

        // Remove padding characters '=' from the length (if any)
        int paddingCount = 0;
        if (base64Pdf.endsWith("==")) {
            paddingCount = 2;
        } else if (base64Pdf.endsWith("=")) {
            paddingCount = 1;
        }

        // Calculate the actual byte size
        int actualSizeInBytes = (int) (Math.ceil((base64Length - paddingCount) * 3 / 4.0));

        // Compare with the size threshold (5 MB)
        int fiveMBInBytes = 5 * 1024 * 1024;
        return actualSizeInBytes <= fiveMBInBytes;
    }

    public static String getFileNameFromUri(@NonNull Context context, @NonNull Uri uri) {
        String fileName = null;
        // Query the Uri for the display name
        if (Objects.equals(uri.getScheme(), "content")) {
            try (Cursor cursor = context.getContentResolver().query(uri, null, null, null, null)) {
                if (cursor != null && cursor.moveToFirst()) {
                    int nameIndex = cursor.getColumnIndex(OpenableColumns.DISPLAY_NAME);
                    if (nameIndex != -1) {
                        fileName = cursor.getString(nameIndex);
                    }
                }
            }
        }
        // If the Uri scheme is "file", extract the file name directly
        if (fileName == null && Objects.equals(uri.getScheme(), "file")) {
            fileName = new File(Objects.requireNonNull(uri.getPath())).getName();
        }

        return fileName;
    }


    public static boolean isCorrectLocation(@Nullable Location location, int accuracy) {
        if (location == null) return false;
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.S) {
            if (location.isMock()) return false;
        } else {
            if (location.isFromMockProvider()) return false;
        }
//        return true;
        return location.getAccuracy() <= accuracy;
    }

    public static void address(String address, @NonNull Context context) {
        Uri uri = Uri.parse(address);
        Intent i = new Intent(Intent.ACTION_VIEW, uri);
        context.startActivity(Intent.createChooser(i, "Please select Browser"));
    }

    public static void bkp(@NonNull Context context) {
        DialogFinalBinding dialogFinalBinding = DialogFinalBinding.inflate(LayoutInflater.from(context));
        androidx.appcompat.app.AlertDialog alertDialog = new androidx.appcompat.app.AlertDialog.Builder(context).setView(dialogFinalBinding.getRoot())
                .setPositiveButton(R.string.ok, null)
                .setNegativeButton(R.string.close, (d, v1) -> d.dismiss())
                .setCancelable(false)
                .create();
        alertDialog.show();
        dialogFinalBinding.editTextReview.setText("jal_rekha_app.db");
        alertDialog.getButton(DialogInterface.BUTTON_POSITIVE).setOnClickListener(view -> {
            String review = dialogFinalBinding.editTextReview.getText().toString();
            if (review.isEmpty()) {
                Utility.show(context, Utility.check(context, R.string.review));
                return;
            }
            try {
                DatabaseMailer.emailDatabase(context, review);
            } catch (Exception e) {
                Utility.show(context, e);
            }
        });
    }


    public static void saveFileInternal(@NonNull String fileContent, @NonNull Context context, @NonNull OnFile onFile) {
        ProgressDialog.startDialog(context, R.string.please_wait);
        ExecutorService executor = Executors.newSingleThreadExecutor();
        Handler handler = new Handler(Looper.getMainLooper());
        executor.execute(() -> {
            try {
                String fileName = System.currentTimeMillis() + ".b64";
                FileOutputStream fos = context.openFileOutput(fileName, Context.MODE_PRIVATE);
                fos.write(fileContent.getBytes());
                fos.close();
                handler.post(() -> {
                    ProgressDialog.stopDialog();
                    onFile.onReceived(fileName, null);
                });
            } catch (Exception e) {
                handler.post(() -> {
                    ProgressDialog.stopDialog();
                    onFile.onReceived(null, e);
                });
            }
//            ProgressDialog.dismissProgress();
        });
    }


    public static void readFileInternal(@NonNull String fileName, @NonNull Context context, @NonNull OnFile onFile) {
        ProgressDialog.startDialog(context, R.string.please_wait);
        ExecutorService executor = Executors.newSingleThreadExecutor();
        Handler handler = new Handler(Looper.getMainLooper());

        executor.execute(() -> {
            try (BufferedInputStream bis = new BufferedInputStream(context.openFileInput(fileName))) {
                byte[] buffer = new byte[bis.available()];
                int bytesRead = bis.read(buffer);
                String fileContent = new String(buffer, 0, bytesRead);
                Log.e("ABCD_C",fileContent);
                handler.post(() -> {
                    ProgressDialog.stopDialog();
                    onFile.onReceived(fileContent, null);
                });
            } catch (Exception e) {
                Log.e("ABCD_E",e.getMessage());
                handler.post(() -> {
                    ProgressDialog.stopDialog();
                    onFile.onReceived(null, e);
                });
            }
        });
    }

    @NonNull
    public static String reading(double kl) {
        return String.format(Locale.UK, "%.1f", kl);
    }

    public static void syncDhara(@Nullable AlertDialog alertDialog, @NonNull Module module, @NonNull Activity context, @NonNull Login login, @Nullable SyncAdapter syncAdapter, @Nullable View.OnClickListener onClickListener) {
        Data data = new Data();
        data.put(Utility.E_TOKEN, login.getToken());//Utility.getDeviceID(this));
        new ApiCaller(context, (response, key) -> {
            ProgressDialog.startDialog(context);
            ExecutorService executor = Executors.newSingleThreadExecutor();
            Handler handler = new Handler(Looper.getMainLooper());
            executor.execute(() -> {
                try {
                    JSONObject jsonObject = new JSONObject(response);
                    SqLite sqLite = SqLite.instance(context);
                    if (jsonObject.getBoolean(Utility.SUCCESS)) {
                        sqLite.CLEAR_DHARA_ESR_VILLAGE();
                        sqLite.CLEAR_DHARA_COMPONENT();
                        sqLite.resetLastTime(module);

                        JSONObject jsonObject1 = jsonObject.getJSONObject(Utility.DATA);
                        JSONObject jsonObject2;
                        JSONArray jsonArray;
                        String date1 = Utility.getCurrentDate().second;
                        String date2 = Utility.getCurrentDate(1).second;
                        if (jsonObject1.has("Ohsr_Oht_Vill") && !jsonObject1.isNull("Ohsr_Oht_Vill")) {
                            jsonArray = jsonObject1.getJSONArray("Ohsr_Oht_Vill");
                            for (int i = 0; i < jsonArray.length(); i++) {
                                jsonObject2 = jsonArray.getJSONObject(i);

                                sqLite.ADD_DHARA_ESR_VILLAGE(new ESRVillage(
                                        jsonObject2.getInt("vill_cd"),
                                        jsonObject2.getString("vil_nm_e"),
                                        jsonObject2.getInt("ohsr_code"),
                                        jsonObject2.getString("ohsr_name"),
                                        jsonObject2.getDouble("start_reading"),
                                        jsonObject2.getDouble("end_reading"),
                                        jsonObject2.getString("remark"),
                                        jsonObject2.getString("photo_path_end_reading"),
                                        jsonObject2.getString("start_reading_date"),
                                        date1
                                ));

                                sqLite.ADD_DHARA_ESR_VILLAGE(new ESRVillage(
                                        jsonObject2.getInt("vill_cd"),
                                        jsonObject2.getString("vil_nm_e"),
                                        jsonObject2.getInt("ohsr_code"),
                                        jsonObject2.getString("ohsr_name"),
                                        jsonObject2.getDouble("yesterday_start_reading"),
                                        jsonObject2.getDouble("yesterday_end_reading"),
                                        jsonObject2.getString("yesterday_remark"),
                                        jsonObject2.getString("yesterday_photo_path_end_reading"),
                                        jsonObject2.getString("yesterday_start_reading_date"),
                                        date2
                                ));
                            }
                        }
                        if (jsonObject1.has("Ohsr_Oht_Vill") && !jsonObject1.isNull("Ohsr_Oht_Vill")) {
                            jsonArray = jsonObject1.getJSONArray("Assigne_User_To_Survey");
                            for (int i = 0; i < jsonArray.length(); i++) {
                                jsonObject2 = jsonArray.getJSONObject(i);
                                sqLite.ADD_DHARA_COMPONENT(new DharaComponent(
                                                jsonObject2.getInt("alotement_type"),
                                                jsonObject2.getInt("maping_id"),
                                                jsonObject2.getString("alotement_type_name"),
                                                jsonObject2.getInt("scheme_id"),
                                                jsonObject2.getString("scheme_name"),
                                                jsonObject2.getInt("wtp_id"),
                                                jsonObject2.getInt("esr_oht_code"),
                                                jsonObject2.getString("esr_name"),
                                                jsonObject2.getInt("bid"),
                                                jsonObject2.optString("beneficiary", "N/A"),
                                                jsonObject2.getInt("meter_id"),
                                                jsonObject2.getString("meter_name"),
                                                jsonObject2.getDouble("start_reading"),
                                                jsonObject2.getDouble("end_reading"),
                                                jsonObject2.getString("remark"),
                                                jsonObject2.getString("photo_path_end_reading"),
                                                jsonObject2.getString("start_reading_date"),
                                                date1,
                                                jsonObject2.getDouble("latitude"),
                                                jsonObject2.getDouble("longitude"),
                                                false,
                                                0
                                        )
                                );
                                sqLite.ADD_DHARA_COMPONENT(new DharaComponent(
                                                jsonObject2.getInt("alotement_type"),
                                                jsonObject2.getInt("maping_id"),
                                                jsonObject2.getString("alotement_type_name"),
                                                jsonObject2.getInt("scheme_id"),
                                                jsonObject2.getString("scheme_name"),
                                                jsonObject2.getInt("wtp_id"),
                                                jsonObject2.getInt("esr_oht_code"),
                                                jsonObject2.getString("esr_name"),
                                                jsonObject2.getInt("bid"),
                                                jsonObject2.optString("beneficiary", "N/A"),
                                                jsonObject2.getInt("meter_id"),
                                                jsonObject2.getString("meter_name"),
                                                jsonObject2.getDouble("yesterday_start_reading"),
                                                jsonObject2.getDouble("yesterday_end_reading"),
                                                jsonObject2.getString("yesterday_remark"),
                                                jsonObject2.getString("yesterday_photo_path_end_reading"),
                                                jsonObject2.getString("yesterday_start_reading_date"),
                                                date2,
                                                jsonObject2.getDouble("yesterday_latitude"),
                                                jsonObject2.getDouble("yesterday_longitude"),
                                                false,
                                                0
                                        )
                                );
                            }
                        }
                        sqLite.updateLastTime(module);

                        handler.post(() -> {
                            try {
                                if (alertDialog != null) {
                                    alertDialog.dismiss();
                                    Utility.show(context, jsonObject.getString(Utility.MESSAGE));
                                }
                            } catch (Exception e) {
                                Utility.show(context, e);
                            }
                        });
                    } else {
                        handler.post(() -> {
                            try {
                                Utility.show(context, jsonObject.getString(Utility.MESSAGE));
                            } catch (Exception e) {
                                Utility.show(context, e);
                            }
                        });
                    }
                } catch (Exception e) {
                    handler.post(() -> Utility.show(context, e));
                }
                handler.post(() -> {
                    if (syncAdapter != null) {
                        syncAdapter.notifyDataSetChanged();
                    }
                    if (onClickListener != null) {
                        onClickListener.onClick(null);
                    }
//                        String ls = SqLite.instance(this).getLastTime(module);
//                        dialogSyncBinding.textViewLastSyncISA.setText(ls == null ? "N/A" : ls);
                    ProgressDialog.stopDialog();
                });
            });
        }, 1, data.toString(), context.getString(R.string.please_wait)).start(API.DHARA.SYNC);
    }








