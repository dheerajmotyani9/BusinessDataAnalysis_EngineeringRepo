    public static Spanned html(String string) {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.N) {
            return Html.fromHtml(string, Html.FROM_HTML_MODE_LEGACY);
        } else {
            //noinspection deprecation
            return Html.fromHtml(string);
        }
    }

    public static void goFirst(@NonNull Activity activity) {
        goFirst(activity, false);
    }

    public static void goFirst(@NonNull Activity activity, boolean clear) {
        Intent intent;
        Login login = SqLite.instance(activity).getLogin();
        if (login != null) {
            if (login.getRole().equals("Contractor")) {
                if (login.getRoleId() == 10) {
                    intent = new Intent(activity, DashboardActivity.class);
                } else {
                    intent = new Intent(activity, RFIDBActivity.class);
                }
            } else {
                intent = new Intent(activity, DashboardActivity.class);
            }
        } else {
            intent = new Intent(activity, LoginActivity.class);
        }
        if (clear) {
            intent.addFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_CLEAR_TASK | Intent.FLAG_ACTIVITY_NEW_TASK);
        }
        activity.startActivity(intent);
        activity.overridePendingTransition(R.anim.fade_in, R.anim.fade_out);
        activity.finish();
    }

    public static void show(@NonNull Context context, @NonNull String message) {
        if (!message.isEmpty() && !message.equals("null")) {
            Toast.makeText(context, message, Toast.LENGTH_SHORT).show();
        }
    }

    public static void show(@NonNull Context context, @Nullable Exception exception) {
        Toast.makeText(context, (exception == null || exception.getMessage() == null) ? "Unknown Error" : exception.getMessage(), Toast.LENGTH_SHORT).show();
    }

    public static void show(@NonNull Context context, @NonNull @StringRes Integer message) {
        Toast.makeText(context, message, Toast.LENGTH_SHORT).show();
    }


