    public static void deleteFileInternal(@NonNull String fileName, @NonNull Context context) {
        Log.e("ABCD_DLTExt","Delete INIT "+fileName);
        try {
            context.deleteFile(fileName);
            Log.e("ABCD_DLTExt","Success delete "+fileName);
        }catch (Exception e){
            Log.e("ABCD_DLTExt","Error in delete "+e.getMessage());
        }
        Log.e("ABCD_DLTExt","Delete END "+fileName);
    }

