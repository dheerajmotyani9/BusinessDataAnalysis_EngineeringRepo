    @NonNull
    public static Bitmap getResizedBitmap(@NonNull Bitmap bm) {
        int newWidth = 612;
        int newHeight = 816;
        int width = bm.getWidth();
        int height = bm.getHeight();
        float scaleWidth = ((float) newWidth) / width;
        float scaleHeight = ((float) newHeight) / height;
        // CREATE A MATRIX FOR THE MANIPULATION
        Matrix matrix = new Matrix();
        // RESIZE THE BIT MAP
        matrix.postScale(scaleWidth, scaleHeight);
        // "RECREATE" THE NEW BITMAP
        Bitmap resizedBitmap = Bitmap.createBitmap(bm, 0, 0, width, height, matrix, false);
        bm.recycle();
        return resizedBitmap;
    }

    @NonNull
    public static String getCurrentTimeUsingDate() {
        Date date = new Date();
        String strDateFormat = "yyyy-MM-dd HH:mm:ss.SSS";
        DateFormat dateFormat = new SimpleDateFormat(strDateFormat, Locale.getDefault());
        return dateFormat.format(date);
    }

    @NonNull
    public static String getCurrentTimeSync() {
        Date date = new Date();
        String strDateFormat = "dd MMM, yyyy hh:mm a";
        DateFormat dateFormat = new SimpleDateFormat(strDateFormat, Locale.getDefault());
        return dateFormat.format(date);
    }

    @NonNull
    public static String getFormatedDate(@NonNull String dateServer) {
        String strDateFormat1 = "dd MMM, yyyy";
        String strDateFormat2 = "yyyy-MM-dd";
        DateFormat dateFormat1 = new SimpleDateFormat(strDateFormat1, Locale.getDefault());
        DateFormat dateFormat2 = new SimpleDateFormat(strDateFormat2, Locale.getDefault());
        try {
            Date date = dateFormat2.parse(dateServer);
            if (date != null) {
                return dateFormat1.format(date);
            }
        } catch (ParseException ignored) {
        }
        return dateServer;
    }

    @NonNull
    public static Pair<String, String> getCurrentTimeOnly() {
        Date date = new Date();
        String strDateFormat1 = "hh:mm a";
        String strDateFormat2 = "HH:mm:ss";
        DateFormat dateFormat1 = new SimpleDateFormat(strDateFormat1, Locale.getDefault());
        DateFormat dateFormat2 = new SimpleDateFormat(strDateFormat2, Locale.getDefault());
        return new Pair<>(dateFormat1.format(date), dateFormat2.format(date));
    }

    @NonNull
    public static Pair<String, String> getCurrentDate() {
        Date date = new Date();
        String strDateFormat1 = "dd MMM, yyyy";
        String strDateFormat2 = "yyyy-MM-dd";
        DateFormat dateFormat1 = new SimpleDateFormat(strDateFormat1, Locale.getDefault());
        DateFormat dateFormat2 = new SimpleDateFormat(strDateFormat2, Locale.getDefault());
        return new Pair<>(dateFormat1.format(date), dateFormat2.format(date));
    }

    @NonNull
    public static Pair<String, String> getCurrentDate(int day) {
        Calendar calendar = Calendar.getInstance();
        calendar.add(Calendar.DAY_OF_MONTH, -day);
        String strDateFormat1 = "dd MMM, yyyy";
        String strDateFormat2 = "yyyy-MM-dd";
        DateFormat dateFormat1 = new SimpleDateFormat(strDateFormat1, Locale.getDefault());
        DateFormat dateFormat2 = new SimpleDateFormat(strDateFormat2, Locale.getDefault());
        return new Pair<>(dateFormat1.format(calendar.getTime()), dateFormat2.format(calendar.getTime()));
    }

    @NonNull
    public static String getMyTimeUsingDate(String date_time) {
        DateFormat dateFormatOut = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss.SSS", Locale.getDefault());
        DateFormat dateFormatIn = new SimpleDateFormat("dd/MM/yyyy HH:mm:ss", Locale.getDefault());
        try {
            return dateFormatOut.format(Objects.requireNonNull(dateFormatIn.parse(date_time)));
        } catch (ParseException e) {
            throw new RuntimeException(e);
        }
    }

    public static String fileToBase64(@NonNull File photoFile) {

        ByteArrayOutputStream objByteArrayOS = new ByteArrayOutputStream();
        byte[] byteBufferString = new byte[1024];
        try {
            System.out.println("file = >>>> <<<<<" + photoFile.getAbsolutePath());
            try (FileInputStream objFileIS = new FileInputStream(photoFile.getAbsolutePath())) {
                for (int readNum; (readNum = objFileIS.read(byteBufferString)) != -1; ) {
                    objByteArrayOS.write(byteBufferString, 0, readNum);
                    System.out.println("read " + readNum + " bytes,");
                }
            }
        } catch (Exception ignored) {
//            e.printStackTrace();
        }
        return Base64.encodeToString(objByteArrayOS.toByteArray(), Base64.DEFAULT);
    }

