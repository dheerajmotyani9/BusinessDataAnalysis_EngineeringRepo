package mapitgis.jalnigam.dhara1;

import androidx.annotation.NonNull;

import com.google.android.gms.maps.model.LatLng;

import java.util.Locale;

import mapitgis.jalnigam.BuildConfig;
import mapitgis.jalnigam.core.Utility;

public class ESRVillage {
    private final int lgd,esrId;
    private final String name, esr;
    private final double r1, r2;
    private double r;
    private final String date,fDate,r1Date;
    private String remark,photo;
    private LatLng latLng;

    public ESRVillage(int lgd, String name, int esrId, String esr, double r1, double r2, String remark, String photo,String r1Date,String date) {
        this.lgd = lgd;
        this.name = name;
        this.esrId = esrId;
        this.esr = esr;
        this.r1 = r1;
        this.r2 = r2;
        this.remark = remark;
        this.photo = photo;
        this.r1Date = r1Date;
        this.date = date;
        this.fDate = Utility.getFormatedDate(date);
        this.r = r2;
    }

    public void setReading(@NonNull Reading reading) {
        this.r = reading.getR2();
        this.remark = reading.getRemark();
        this.latLng = reading.getLatLng();
        this.photo = reading.getPhoto();
    }

    public void setLatLng(LatLng latLng) {
        this.latLng = latLng;
    }

    public LatLng getLatLng() {
        return latLng;
    }

    public String getR1Date() {
        return r1Date;
    }

    public String getDate() {
        return date;
    }

    public String getRemark() {
        return remark;
    }

    public String getPhoto() {
        return photo;
    }

    public void setPhoto(String photo) {
        this.photo = photo;
    }

    public void setRemark(String remark) {
        this.remark = remark;
    }

    public double getR() {
        return r;
    }

    public String getName() {
        return name;
    }

    public int getLgd() {
        return lgd;
    }

    public int getEsrId() {
        return esrId;
    }

    public String getEsr() {
        return esr;
    }

    public double getR1() {
        return r1;
    }

    public double getR2() {
        return r2;
    }

    public void setR(double r) {
        this.r = r;
    }

    public String getTotal() {
        double ttl = r - r1;
        return String.format(Locale.UK, "%.1f", ttl > 0 ? ttl : 0);
    }


    public String getR1Reading() {
        return Utility.reading(r1);
    }
    public String getR2Reading() {
        return Utility.reading(r2);
    }

    public String getRReading() {
        return Utility.reading(r);
    }

    public String getR1DateDetail() {
        return String.format("Start Reading as date : %s", r1Date);
    }


    public String getFDate() {
        return fDate;
    }

    public String getRemarkWithNA() {
        return remark.isEmpty()?"N/A":remark;
    }

    public String getFullPhotoURL() {
        return String.format("%s%s", BuildConfig.JAL_NIGAM_IMAGE,photo);
    }
}
