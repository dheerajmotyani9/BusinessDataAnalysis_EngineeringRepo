package mapitgis.jalnigam.isa;

public class ISA {
    private final long id;
    private boolean uploaded;
    private final double lat,lng;
    private final String gpId, gp, villageId, village, activityId, activity, remark,date,capture,address;
    private boolean doc,img;

    public ISA(long id, boolean uploaded, String gpId, String gp, String villageId, String village, String activityId, String activity, String remark,String date,String capture,double lat,double lng,String address,boolean doc,boolean img) {
        this.id = id;
        this.uploaded = uploaded;
        this.gpId = gpId;
        this.gp = gp;
        this.villageId = villageId;
        this.village = village;
        this.activityId = activityId;
        this.activity = activity;
        this.remark = remark;
        this.date = date;
        this.capture = capture;
        this.lat = lat;
        this.lng = lng;
        this.address = address;
        this.doc = doc;
        this.img = img;
    }

    public ISA(boolean uploaded,String gpId, String gp, String villageId, String village, String activityId, String activity, String remark,String date,String capture,double lat,double lng,String address,boolean doc,boolean img) {
        this.id = 0;
        this.uploaded = uploaded;
        this.gpId = gpId;
        this.gp = gp;
        this.villageId = villageId;
        this.village = village;
        this.activityId = activityId;
        this.activity = activity;
        this.remark = remark;
        this.date = date;
        this.capture = capture;
        this.lat = lat;
        this.lng = lng;
        this.address = address;
        this.doc = doc;
        this.img = img;
    }

    public double getLat() {
        return lat;
    }

    public double getLng() {
        return lng;
    }

    public String getAddress() {
        return address;
    }

    public String getDate() {
        return date;
    }

    public long getId() {
        return id;
    }

    public String getGpId() {
        return gpId;
    }

    public String getGp() {
        return gp;
    }

    public String getVillageId() {
        return villageId;
    }

    public String getVillage() {
        return village;
    }

    public String getActivityId() {
        return activityId;
    }

    public String getActivity() {
        return activity;
    }

    public String getRemark() {
        return remark;
    }

    public boolean isUploaded() {
        return uploaded;
    }

    public void setUploaded(boolean uploaded) {
        this.uploaded = uploaded;
    }

    public boolean isDoc() {
        return doc;
    }

    public boolean isImg() {
        return img;
    }

    public String getCapture() {
        return capture;
    }
}
