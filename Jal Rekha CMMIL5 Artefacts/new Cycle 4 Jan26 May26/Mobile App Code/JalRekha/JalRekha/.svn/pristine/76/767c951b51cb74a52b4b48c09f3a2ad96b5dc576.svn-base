package mapitgis.jalnigam.room.dao;

import androidx.lifecycle.LiveData;
import androidx.room.Dao;
import androidx.room.Insert;
import androidx.room.Query;

import java.util.List;

import mapitgis.jalnigam.room.table.AnushravanStatusTable;
import mapitgis.jalnigam.room.table.ApplicationTypeTable;
import mapitgis.jalnigam.room.table.BlockTable;
import mapitgis.jalnigam.room.table.ComponentTypeTable;
import mapitgis.jalnigam.room.table.GramTable;
import mapitgis.jalnigam.room.table.InspectionRequestTable;
import mapitgis.jalnigam.room.table.LocationTable;
import mapitgis.jalnigam.room.table.MediaTable;
import mapitgis.jalnigam.room.table.PipeLineTable;
import mapitgis.jalnigam.room.table.PointTable;
import mapitgis.jalnigam.room.table.VillageTable;

@Dao
public interface JalRekhaDao {

    @Insert
    void insertApplicationType(ApplicationTypeTable table);

    @Query("Select * from application_type_table")
    LiveData<List<ApplicationTypeTable>> getApplicationType();

    @Insert
    void insertComponent(ComponentTypeTable component);

    @Query("Select * from component_type_table")
    LiveData<List<ComponentTypeTable>> getComponent();


    @Insert
    void insertLocation(LocationTable location);

    @Query("Select DISTINCT block_id,block_name from location_table")
    LiveData<List<BlockTable>> getBlock();

    @Query("Select DISTINCT gram_id,gram_name from location_table WHERE block_id =:blockId")
    LiveData<List<GramTable>> getGramPanchayat(String blockId);

    @Query("Select DISTINCT village_id,village_name from location_table WHERE gram_id =:gramId")
    LiveData<List<VillageTable>> getVillage(String gramId);

    @Insert
    void insertPoint(PointTable pointTable);

    @Query("Select * from point_table WHERE cid =:pointId")
    LiveData<List<PointTable>> getPoint(String pointId);

    // TODO: 09-07-2024 : add inspection request
    @Insert
    long insertInspectionRequest(InspectionRequestTable table);

    @Insert
    void insertAllInspectionRequest(List<InspectionRequestTable> inspectionList);

    @Query("Select * from inspection_request_table WHERE saved_by = :savedBy AND saved_by_login_id = :savedById ORDER BY (CASE WHEN upload_status = 0 OR rfi_id<=0 THEN 0 ELSE 1 END) ASC,rfi_id DESC")//upload_status ASC,//CASE WHEN upload_status = 0 THEN 0 ELSE 1 END
    LiveData<List<InspectionRequestTable>> getInspection(String savedBy,String savedById);

    @Query("Select * from inspection_request_table WHERE saved_by = :savedBy AND saved_by_login_id = :savedById  AND status = :status ORDER BY (CASE WHEN upload_status = 0 OR rfi_id<=0 THEN 0 ELSE 1 END) ASC,rfi_id DESC") //CASE WHEN upload_status = 0 THEN 0 ELSE 1 END
    LiveData<List<InspectionRequestTable>> getReInspection(String savedBy,String savedById,String status);

    @Query("UPDATE inspection_request_table SET upload_status = :status WHERE id = :id")
    void updateInspectionStatus(int id, int status);

    @Query("DELETE FROM inspection_request_table WHERE id = :id")
    void deleteInspectionById(int id);

    @Query("DELETE FROM inspection_request_table WHERE upload_status = 1")
    void deleteInspectionByUploadStatus();

    @Insert
    void insertMediaFile(MediaTable table);

    @Query("DELETE FROM media_table WHERE request_id = :id")
    void deleteMediaByInspectionId(long id);

    @Query("Select * from media_table WHERE request_id =:reqId")
    LiveData<List<MediaTable>> getMediaFile(long reqId);

    /**
     * anushravan status: add and get
     */
    @Insert
    void insertAnushravanStatus(List<AnushravanStatusTable> statusList);

    @Query("Select DISTINCT id,status_name,status_group,status_group_name,status_id from status_table")
    LiveData<List<AnushravanStatusTable>> getAnushravanStatus();

    // TODO: 09-07-2024 : delete data
    @Query("DELETE FROM component_type_table")
    void deleteAllComponent();

    @Query("DELETE FROM application_type_table")
    void deleteAllApplicationType();

    @Query("DELETE FROM location_table")
    void deleteAllLocation();

    @Query("DELETE FROM  point_table")
    void deleteAllPoints();

    @Query("DELETE FROM status_table")
    void deleteAllStatus();

    @Query("DELETE FROM  inspection_request_table")
    void deleteAllInspectionRequest();

    @Query("DELETE FROM media_table")
    void deleteAllMedia();

    /*for pipleline master table*/
    @Query("DELETE FROM pipe_line_master")
    void deleteAllPipeLine();

    @Insert
    void insertPipeLine(List<PipeLineTable> pipeLineList);

    @Query("Select DISTINCT surveyUid from pipe_line_master where schemeId =:schemeId AND componentId =:componentId")
    LiveData<List<String>> getPipelineOHTMBR(String schemeId, int componentId);

    @Query("Select * from pipe_line_master where schemeId =:schemeId AND componentId =:componentId AND surveyUid =:surveyUid")
    LiveData<List<PipeLineTable>> getPipelineList(String schemeId, int componentId, String surveyUid);

    @Query("Select * from pipe_line_master where schemeId =:schemeId AND componentId =:componentId order by pipNo ASC")
    LiveData<List<PipeLineTable>> getPipelineListFOR_CWPM_RWPM(String schemeId, int componentId);

    @Query("Select * from pipe_line_master where schemeId =:schemeId AND componentId =:componentId AND surveyUid =:surveyUid AND pipNo =:pipeNo order by pipNo ASC")
    LiveData<PipeLineTable> getPipelineDetail(String schemeId, int componentId, String surveyUid,String pipeNo);

    @Query("Select * from pipe_line_master where schemeId =:schemeId AND componentId =:componentId AND pipNo =:pipeNo")
    LiveData<PipeLineTable> getPipelineDetailFOR_CWPM_RWPM(String schemeId, int componentId,String pipeNo);

    @Query("DELETE FROM sqlite_sequence WHERE name = 'pipe_line_master'")
    void resetPipelineMasterAutoIncrement();


}
