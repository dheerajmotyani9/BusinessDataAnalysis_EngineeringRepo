<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="android.view.View"/>
        <variable
            name="transaction"
            type="mapitgis.jalnigam.nirmal.database.table.NirmalWQMEntity" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.app.viewcomponent.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:key="SampleID"
                    app:value="@{transaction.sampleId}"
                    app:valueTextStyle="bold"
                    app:valueTextColor="@color/green"/>

                <!--<Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="View"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/gray"
                    android:padding="8dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"/>-->

            </RelativeLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:orientation="horizontal"
                    android:background="@color/whiteGray"
                    app:layout_constraintTop_toTopOf="parent">

                    <RelativeLayout
                        android:layout_width="96dp"
                        android:layout_height="match_parent"
                        android:padding="2dp">

                        <ImageView
                            android:id="@+id/sample_img"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            app:imageUri="@{transaction.sampleImgFilePath}"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="4dp"
                            android:gravity="center"
                            android:layout_alignParentBottom="true"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:text="Water Sample"
                            android:background="@color/transparent_color"/>
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="96dp"
                        android:layout_height="match_parent"
                        android:padding="2dp"
                        android:visibility='@{transaction.collectionId==1 ? View.INVISIBLE : View.VISIBLE}'>

                        <ImageView
                            android:id="@+id/frc_img"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            app:imageUri="@{transaction.frcImgFilePath}"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="4dp"
                            android:gravity="center"
                            android:layout_alignParentBottom="true"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:text="FRC Test"
                            android:background="@color/transparent_color"/>

                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="4dp"
                        android:gravity="center"
                        android:visibility='@{transaction.collectionId==1 ? View.INVISIBLE : View.VISIBLE}'>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FRC Result"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{transaction.frcTestResult}"
                                android:textColor="@color/green"
                                android:textSize="32sp"
                                android:includeFontPadding="false"
                                android:textStyle="bold"
                                android:fontFamily="@font/helvetica_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="mg/L"
                                android:textColor="@color/black"
                                android:textSize="10sp"
                                android:fontFamily="@font/digital_italic"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/gray"
                            android:text="@{transaction.getFormattedDate}"/>

                    </LinearLayout>

                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:background="@drawable/baseline_article_24"/>

            </androidx.constraintlayout.widget.ConstraintLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:visibilityGone='@{transaction.uploaded ==0 ? true : false}'>

                <Button
                    android:id="@+id/btn_discard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/red"
                    android:text="@string/discard"
                    android:textAllCaps="false"/>


                <Button
                    android:id="@+id/btn_upload"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/upload"
                    android:textAllCaps="false"/>


            </LinearLayout>


        </LinearLayout>



    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>