    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toStartOf="@id/layout_emf_reading_remove_iv">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Village Reading"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/layout_emf_reading_village_name_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Village Name: NAME HERE"
            android:textColor="@color/black"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/layout_emf_reading_village_start_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start: 1200"
            android:textColor="@color/black"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/layout_emf_reading_village_end_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="End: 1200"
            android:textColor="@color/black"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/layout_emf_reading_village_total_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: 1200"
            android:textColor="@color/black"
            android:textSize="12sp" />

    </LinearLayout>
    <ImageView
        android:id="@+id/layout_emf_reading_remove_iv"
        android:layout_width="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_height="wrap_content"
        android:src="@drawable/baseline_cancel_24"
        app:tint="@color/redColor" />



</RelativeLayout>

