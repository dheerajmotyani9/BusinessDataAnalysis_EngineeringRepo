<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <include
        android:id="@+id/appbar"
        layout="@layout/toolbar" />


    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/dp16">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp5"
                android:text="@string/scheme"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/linearLayoutScheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/dp20"
                android:paddingEnd="@dimen/dp20">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp" />

                <ImageView
                    android:layout_width="@dimen/dp20"
                    android:layout_height="@dimen/dp20"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="?attr/colorPrimary" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp5"
                android:text="@string/component"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/linearLayoutComponent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/dp20"
                android:paddingEnd="@dimen/dp20">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp" />

                <ImageView
                    android:layout_width="@dimen/dp20"
                    android:layout_height="@dimen/dp20"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="?attr/colorPrimary" />

            </LinearLayout>


            <TextView
                android:id="@+id/textViewESR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp5"
                android:text="@string/esr"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/linearLayoutESR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/dp20"
                android:paddingEnd="@dimen/dp20">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp" />

                <ImageView
                    android:layout_width="@dimen/dp20"
                    android:layout_height="@dimen/dp20"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="?attr/colorPrimary" />

            </LinearLayout>


            <TextView
                android:id="@+id/textViewPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp5"
                android:text="@string/points"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/linearLayoutPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/dp20"
                android:paddingEnd="@dimen/dp20">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp" />

                <ImageView
                    android:layout_width="@dimen/dp20"
                    android:layout_height="@dimen/dp20"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="?attr/colorPrimary" />

            </LinearLayout>

            <EditText
                android:id="@+id/editTextPointName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:background="@drawable/edit_box"
                android:hint="Enter Point Name"
                android:importantForAutofill="no"
                android:inputType="text"
                android:lines="1"
                android:maxLines="1"
                android:padding="@dimen/dp5"
                android:singleLine="true"
                android:textColor="@color/colorPrimary"
                android:textCursorDrawable="@null"
                android:textSize="14sp"
                android:visibility="gone" />


            <!--            <TextView-->
            <!--                android:id="@+id/textViewPastPoints"-->
            <!--                android:layout_width="wrap_content"-->
            <!--                android:layout_height="wrap_content"-->
            <!--                android:layout_marginTop="@dimen/dp10"-->
            <!--                android:layout_marginBottom="@dimen/dp5"-->
            <!--                android:text="@string/linked_with_last_point"-->
            <!--                android:textColor="@color/colorPrimary"-->
            <!--                android:textSize="14sp" />-->

            <!--            <LinearLayout-->
            <!--                android:id="@+id/linearLayoutPastPoints"-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="wrap_content"-->
            <!--                android:background="@drawable/spinner_bg"-->
            <!--                android:gravity="center"-->
            <!--                android:orientation="horizontal"-->
            <!--                android:paddingStart="@dimen/dp20"-->
            <!--                android:paddingEnd="@dimen/dp20">-->

            <!--                <TextView-->
            <!--                    android:layout_width="0dp"-->
            <!--                    android:layout_height="wrap_content"-->
            <!--                    android:layout_weight="1"-->
            <!--                    android:text="@string/select"-->
            <!--                    android:textColor="?attr/colorPrimary"-->
            <!--                    android:textSize="11sp" />-->

            <!--                <ImageView-->
            <!--                    android:layout_width="@dimen/dp20"-->
            <!--                    android:layout_height="@dimen/dp20"-->
            <!--                    android:contentDescription="@string/app_name"-->
            <!--                    android:src="@drawable/ic_arrow_down"-->
            <!--                    app:tint="?attr/colorPrimary" />-->

            <!--            </LinearLayout>-->

            <!--            <Button-->
            <!--                android:id="@+id/buttonTraverse"-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="wrap_content"-->
            <!--                android:layout_marginTop="@dimen/dp10"-->
            <!--                android:text="@string/start_traverse"-->
            <!--                android:visibility="gone" />-->

            <TextView
                android:id="@+id/textViewPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp5"
                android:text="@string/photo"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/linearLayoutImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/dp20"
                android:paddingEnd="@dimen/dp20">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/please_capture_photo"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp" />

                <ImageView
                    android:layout_width="@dimen/dp25"
                    android:layout_height="@dimen/dp25"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_img"
                    app:tint="?attr/colorPrimary" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imageViewPhoto"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="@dimen/dp10"
                android:background="@drawable/edit_box"
                android:contentDescription="@string/app_name"
                android:padding="@dimen/dp5"
                android:scaleType="centerInside"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textViewReview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp5"
                android:text="@string/review"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/editTextReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_box"
                android:hint="@string/review"
                android:importantForAutofill="no"
                android:inputType="text"
                android:lines="1"
                android:maxLines="1"
                android:padding="@dimen/dp5"
                android:singleLine="true"
                android:textColor="@color/colorPrimary"
                android:textCursorDrawable="@null"
                android:textSize="14sp" />


            <TextView
                android:id="@+id/textViewNOR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp5"
                android:text="@string/select_number_of_pipe"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp" />

            <RadioGroup
                android:id="@+id/radioGroupNOR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_box"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="@dimen/dp5"
                    android:tag="1"
                    android:text="@string/one"
                    android:textSize="14sp" />

                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginEnd="0dp"
                    android:tag="2"
                    android:text="@string/two" />

                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp5"
                    android:layout_marginEnd="0dp"
                    android:tag="3"
                    android:text="@string/three" />
            </RadioGroup>

            <Button
                android:id="@+id/buttonSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp20"
                android:text="@string/save" />

        </LinearLayout>

    </ScrollView>

    <FrameLayout
        android:id="@+id/mapBox"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="@dimen/dp10"
        android:background="@drawable/edit_box">

        <com.google.android.gms.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ImageView
            android:id="@+id/imageViewCurrentLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="@dimen/dp5"
            android:layout_marginBottom="50dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_location_searching"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/textViewLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#99000000"
            android:gravity="center"
            android:padding="@dimen/dp5"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

    </FrameLayout>

</LinearLayout>