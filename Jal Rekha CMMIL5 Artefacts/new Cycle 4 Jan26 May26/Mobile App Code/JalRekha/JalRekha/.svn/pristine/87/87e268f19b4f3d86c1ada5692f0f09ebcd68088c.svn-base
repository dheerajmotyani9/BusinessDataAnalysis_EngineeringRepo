package mapitgis.jalnigam.nirmal.screens.wqm_add

import android.app.Application
import android.content.Intent
import android.os.Build
import androidx.lifecycle.LiveData
import androidx.lifecycle.MutableLiveData
import androidx.lifecycle.viewModelScope
import com.google.android.gms.maps.model.LatLng
import kotlinx.coroutines.launch
import mapitgis.jalnigam.core.Utility
import mapitgis.jalnigam.nirmal.base.NirmalBaseViewModel
import mapitgis.jalnigam.nirmal.collection.WaterPointType
import mapitgis.jalnigam.nirmal.database.dao.VillageDetails
import mapitgis.jalnigam.nirmal.database.table.NirmalWQMEntity
import mapitgis.jalnigam.nirmal.database.dao.CombineSurveyTransaction
import mapitgis.jalnigam.nirmal.location.GeofenceUtil

class WQMFormVM(application: Application) : NirmalBaseViewModel(application){

    var waterSampleId : String = ""

    lateinit var collectionType: WaterPointType
    lateinit var surveyTransaction: CombineSurveyTransaction

    private val _villageList = MutableLiveData<List<VillageDetails>>()
    val villageList: LiveData<List<VillageDetails>> get() = _villageList

    //hide show layout for selected collection points
    val isFRCVisible = MutableLiveData<Boolean>().apply { value = false }
    val isBenificiaryVisible = MutableLiveData<Boolean>().apply { value = false }
    val isContactPersonVisible = MutableLiveData<Boolean>().apply { value = false }
    val isOHTESRVisible = MutableLiveData<Boolean>().apply { value = false }
    val isInstituteOtherVisible = MutableLiveData<Boolean>().apply { value = false }

    init {
        waterSampleId = nirmalRepo.generateWaterSampleId()
    }


    fun fetchValueFromIntent(intent: Intent){
        surveyTransaction = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
            intent.getParcelableExtra("survey_transaction", CombineSurveyTransaction::class.java)!!
        } else {
            intent.extras?.getParcelable("survey_transaction")!!
        }

        //for testing only
        /*surveyTransaction = surveyTransaction.copy(
            assetLatitude = 23.2436052,
            assetLongitude = 77.4298743
        )*/
        collectionType = WaterPointType.fromId(surveyTransaction.allotType.toInt())!!

        fetchEsrVillageDetails(surveyTransaction.esrCode)
        setCollectionTypeForm()
    }

    fun getBitmapText():String{
        return "Latitude: ${geoLocation.value?.latitude}\n" +
                "Longitude: ${geoLocation.value?.longitude}\n"+
                "Date: ${Utility.getCurrentTimeSync()}\n"+
                "Name: ${nirmalRepo.login.name}\n"+
                "Number: ${nirmalRepo.login.mobile}"
    }

    private fun setCollectionTypeForm() {
        isFRCVisible.value =collectionType != WaterPointType.WTP_INLET
        isBenificiaryVisible.value = collectionType == WaterPointType.BENEFICIARY
        isContactPersonVisible.value = collectionType == WaterPointType.BULK_METER
        isInstituteOtherVisible.value = collectionType == WaterPointType.BULK_METER
        isOHTESRVisible.value = collectionType == WaterPointType.OHT_ESR || collectionType == WaterPointType.BENEFICIARY
    }

    private fun fetchEsrVillageDetails(esrCode: String) {
        viewModelScope.launch {
            val response = nirmalRepo.getEsrVillageDetails(esrCode)
            _villageList.postValue(response)
        }
    }


    fun insertWQM(NirmalWQMEntity: NirmalWQMEntity) {
        viewModelScope.launch {
            nirmalRepo.insertWQM(NirmalWQMEntity)
            _toastMessage.value = "Saved Successfully"
        }
    }


    fun isAssetLocationValid():Boolean{
        return surveyTransaction.isAssetLocationValid()
    }

    fun isGeofenceValidationRequired(): Boolean {
        return collectionType != WaterPointType.BULK_METER &&
                collectionType != WaterPointType.BENEFICIARY
    }




    fun isUserInsideGeofence():Boolean{
        val location = geoLocation.value ?: return false
        val currentLoc = LatLng(location.latitude, location.longitude)

        val assetLoc = LatLng(surveyTransaction.assetLatitude!!, surveyTransaction.assetLongitude!!)
        if(!GeofenceUtil.isInsideGeofence(currentLoc,assetLoc, GeofenceUtil.GEOFENCE_RADIUS)){
            _toastMessage.value = "User is outside the geofence!"
            return false
        }
        return true
    }

}