<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="mapitgis.jalnigamk.nirmal.collection.WaterPointType"/>

        <variable
            name="viewModel"
            type="mapitgis.jalnigamk.nirmal.screens.contractor.NirmalContractorVM" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <include
            android:id="@+id/appbar"
            layout="@layout/toolbar" />


        <androidx.cardview.widget.CardView
            android:id="@+id/map_card_view"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:layout_constraintTop_toBottomOf="@id/appbar">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <fragment
                    android:id="@+id/map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/address_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    app:cardBackgroundColor="@color/transparent_color">

                    <TextView
                        android:id="@+id/tv_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableLeft="@drawable/ic_baseline_location_on_24"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/white"
                        android:padding="8dp"
                        android:textColor="@color/white"
                        android:text="@{viewModel.geoAddress}"/>

                </androidx.cardview.widget.CardView>

            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/info_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/map_card_view">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:id="@+id/tv_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="Name"
                    app:value="@{viewModel.sessionManager.name}"
                    app:weights="2,8"/>

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="PIU"
                    app:value="@{viewModel.sessionManager.PIU}"
                    app:weights="2,8"/>

                <mapitgis.jalnigamk.nirmal.view.FormKeyValueText
                    android:id="@+id/tv_scheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:key="Scheme"
                    app:value="@{viewModel.sessionManager.scheme}"
                    app:weights="2,8"/>

             </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/info_layout">

            <mapitgis.jalnigamk.nirmal.view.FormSpinner
                android:id="@+id/spin_component"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_vertical"
                app:mandatory="true"
                app:label="Select Component"/>


        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
